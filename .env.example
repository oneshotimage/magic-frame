# Node and FastAPI backends read these KL API settings.
KL_API_BASE_URL=https://api.kl-api.info
KL_API_TOKEN=replace_me
KL_IMAGE_MODEL=gpt-image-2
KL_IMAGE_ENDPOINT=/v1/images/edits
KL_TIMEOUT_SECONDS=600
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Use this only when your local network needs a proxy for KL API.
KL_PROXY_URL=http://127.0.0.1:7890

# Backend console log level: debug, info, warn, error.
LOG_LEVEL=info

# FastAPI backend only: keep unset or 0 for real KL calls.
# Set to 1 only when you need local mock images without spending model quota.
AI_MOCK_GENERATION=0

# FastAPI backend only: test-period switch. Keep 1 to allow unlimited generation.
AI_UNLIMITED_CREDITS=1

# FastAPI admin backend.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# WeChat CloudBase Run / cloud hosting persistence.
# If DATABASE_URL is omitted, FastAPI uses SQLite under DATA_DIR for local dev.
# DATABASE_URL=mysql://user:password@host:3306/database
# WeChat cloud hosting MySQL envs are also supported:
# MYSQL_ADDRESS=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USERNAME=root
# MYSQL_PASSWORD=replace_me
# MYSQL_DATABASE=ai_image
DATA_DIR=.data

# Tencent Cloud COS object storage. If omitted, uploads/generated images fall back to DATA_DIR/objects.
# COS_SECRET_ID=replace_me
# COS_SECRET_KEY=replace_me
# COS_BUCKET=7072-prod-d5gk56llu962b417e-1439090877
# COS_REGION=ap-shanghai
# COS_PREFIX=ai-image
# COS_PUBLIC_BASE_URL=https://7072-prod-d5gk56llu962b417e-1439090877.tcb.qcloud.la
# OBJECT_STORAGE_STRICT=0
