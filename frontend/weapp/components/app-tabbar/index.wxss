.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 35;
  min-height: 154rpx;
  padding: 22rpx 102rpx calc(env(safe-area-inset-bottom) + 23rpx);
  border-radius: 24rpx 24rpx 0 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 108rpx;
  background: #ffffff;
  box-shadow: 0 -8rpx 28rpx rgba(0, 0, 0, 0.06);
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.tab-item {
  min-width: 96rpx;
  height: 102rpx;
  padding: 8rpx 0;
  border-radius: 16rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #645e54;
  flex: none;
}

.tab-item.active {
  color: #7c5800;
}

.tab-icon {
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  line-height: 40rpx;
  font-weight: 800;
}

.home-icon,
.profile-icon {
  font-size: 36rpx;
}

.tab-item.active .tab-icon {
  font-size: 42rpx;
}

.tab-label {
  padding-top: 8rpx;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 500;
  white-space: nowrap;
}
