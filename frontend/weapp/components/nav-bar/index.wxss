.nav-shell {
  left: 0;
  right: 0;
  z-index: 30;
  box-sizing: border-box;
  background: rgba(249, 249, 249, 0.8);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.nav-home {
  background: rgba(255, 252, 247, 0.84);
}

.nav-glass {
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.62) 0%, rgba(0, 0, 0, 0) 100%);
  -webkit-backdrop-filter: none;
  backdrop-filter: none;
}

.nav-bar {
  height: 92rpx;
  padding: 0 40rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #1a1c1c;
}

.nav-home .nav-bar {
  height: 102rpx;
  padding: 0 44rpx;
}

.nav-glass .nav-bar {
  height: 110rpx;
  padding: 0 30rpx;
  color: #ffffff;
}

.nav-compact .nav-bar {
  height: 96rpx;
  padding: 0 40rpx;
}

.nav-glass.nav-compact .nav-bar {
  height: 104rpx;
  padding: 0 30rpx;
}

.is-fixed {
  position: fixed;
  top: 0;
}

.is-static {
  position: relative;
}

.nav-action {
  width: 112rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  flex: none;
}

.nav-home .nav-action {
  width: 150rpx;
  height: 78rpx;
}

.nav-compact .nav-action {
  width: 64rpx;
  height: 64rpx;
}

.nav-glass .nav-action {
  width: 152rpx;
  height: 74rpx;
}

.nav-left {
  justify-content: flex-start;
}

.nav-right {
  justify-content: flex-end;
  pointer-events: none;
}

.nav-back-icon {
  color: #7c5800;
  font-size: 48rpx;
  line-height: 48rpx;
  font-weight: 500;
}

.nav-glass .nav-back-icon {
  width: 70rpx;
  height: 70rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 50%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 58rpx;
  line-height: 62rpx;
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
}

.nav-left-text {
  color: #7c5800;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
  white-space: nowrap;
}

.nav-heading {
  min-width: 0;
  flex: 1;
  color: #1a1c1c;
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 600;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.nav-glass .nav-heading {
  color: #ffffff;
  font-size: 38rpx;
  line-height: 54rpx;
  font-weight: 800;
  text-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.45);
}

.nav-home .nav-heading {
  font-size: 39rpx;
  line-height: 56rpx;
  font-weight: 800;
}

.nav-compact .nav-heading {
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 500;
}

.nav-compact .nav-back-icon {
  color: #7c5800;
  font-size: 46rpx;
  line-height: 46rpx;
}

.nav-glass.nav-compact .nav-heading {
  color: #ffffff;
  font-size: 38rpx;
  line-height: 54rpx;
  font-weight: 800;
}

.nav-glass.nav-compact .nav-back-icon {
  color: #ffffff;
  font-size: 58rpx;
  line-height: 62rpx;
}

.home-gift {
  position: relative;
  width: 44rpx;
  height: 44rpx;
}

.home-gift-box {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 34rpx;
  border: 3rpx solid #19150e;
  border-radius: 7rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.42);
}

.home-gift-box::before {
  content: "";
  position: absolute;
  top: -3rpx;
  bottom: -3rpx;
  left: 50%;
  width: 3rpx;
  background: #19150e;
  transform: translateX(-50%);
}

.home-gift-box text {
  position: relative;
  z-index: 1;
  color: #b78200;
  font-size: 25rpx;
  line-height: 25rpx;
}

.home-gift-bow::before,
.home-gift-bow::after {
  content: "";
  position: absolute;
  top: 0;
  width: 18rpx;
  height: 15rpx;
  border: 3rpx solid #19150e;
  border-radius: 12rpx 12rpx 2rpx 12rpx;
  box-sizing: border-box;
}

.home-gift-bow::before {
  left: 5rpx;
  transform: rotate(20deg);
}

.home-gift-bow::after {
  right: 5rpx;
  border-radius: 12rpx 12rpx 12rpx 2rpx;
  transform: rotate(-20deg);
}
