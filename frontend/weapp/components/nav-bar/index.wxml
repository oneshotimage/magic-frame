<view class="nav-shell {{fixed ? 'is-fixed' : 'is-static'}} {{variant === 'home' ? 'nav-home' : ''}} {{variant === 'glass' ? 'nav-glass' : ''}} {{compact ? 'nav-compact' : ''}}" style="padding-top: {{statusBarHeight}}px;">
  <view class="nav-bar">
    <view class="nav-action nav-left" bindtap="onBack">
      <view wx:if="{{variant === 'home'}}" class="home-gift">
        <view class="home-gift-bow"></view>
        <view class="home-gift-box">
          <text>✦</text>
        </view>
      </view>
      <text wx:elif="{{showBack}}" class="{{leftText.length > 1 ? 'nav-left-text' : 'nav-back-icon'}}">{{leftText}}</text>
    </view>
    <view class="nav-heading">{{title}}</view>
    <view class="nav-action nav-right"></view>
  </view>
</view>
