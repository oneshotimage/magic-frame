.app-button {
  width: 100%;
  height: 112rpx;
  padding: 0 40rpx;
  margin: 0;
  border: 0;
  border-radius: 9999rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #ffb800;
  color: #222222;
  box-shadow: 0 16rpx 24rpx rgba(255, 184, 0, 0.15);
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 36rpx;
  line-height: 54rpx;
  font-weight: 500;
}

.app-button::after {
  border: 0;
}

.app-button[disabled] {
  opacity: 0.56;
}

.button-text,
.button-icon {
  display: block;
  white-space: nowrap;
}

.button-icon {
  font-size: 40rpx;
  line-height: 40rpx;
}

.secondary {
  background: #fff5e8;
  color: #222222;
  box-shadow: none;
}

.dark {
  background: #222222;
  color: #ffffff;
  box-shadow: none;
}

.compact {
  height: 96rpx;
  font-size: 30rpx;
  line-height: 42rpx;
  box-shadow: 0 8rpx 12rpx rgba(255, 184, 0, 0.15);
}

.home-cta {
  height: 108rpx;
  gap: 15rpx;
  font-size: 38rpx;
  line-height: 54rpx;
  box-shadow: 0 15rpx 23rpx rgba(255, 184, 0, 0.25);
}

.mini {
  width: auto;
  min-width: 132rpx;
  height: 72rpx;
  padding: 0 30rpx;
  font-size: 26rpx;
  line-height: 38rpx;
  box-shadow: none;
}
