page {
  min-height: 100vh;
  background: #f8f8f8;
  color: #222222;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 32rpx 40rpx 56rpx;
  background:
    radial-gradient(circle at 0% 0%, rgba(255, 184, 0, 0.18), transparent 30%),
    radial-gradient(circle at 100% 100%, rgba(255, 125, 69, 0.14), transparent 30%),
    #f8f8f8;
  box-sizing: border-box;
}

.safe-tab {
  padding-bottom: calc(env(safe-area-inset-bottom) + 132rpx);
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.card {
  padding: 36rpx;
  border-radius: 48rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(213, 196, 171, 0.62);
  box-shadow: 0 16rpx 48rpx rgba(255, 184, 0, 0.1);
  box-sizing: border-box;
}

.title {
  margin: 0;
  font-size: 48rpx;
  line-height: 64rpx;
  font-weight: 700;
}

.headline {
  margin: 0;
  font-size: 60rpx;
  line-height: 72rpx;
  font-weight: 800;
}

.subtitle {
  margin-top: 12rpx;
  color: #666666;
  font-size: 28rpx;
  line-height: 44rpx;
}

.muted {
  color: #666666;
  font-size: 24rpx;
  line-height: 36rpx;
}

.primary-btn,
.secondary-btn,
.danger-btn {
  width: 100%;
  height: 112rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.primary-btn {
  background: #ffb800;
  color: #222222;
  box-shadow: 0 16rpx 24rpx rgba(255, 184, 0, 0.22);
}

.secondary-btn {
  background: #fff5e8;
  color: #222222;
}

.danger-btn {
  background: #ffdad6;
  color: #ba1a1a;
}

.grid-two {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
}

.credit-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  border: 1rpx solid rgba(255, 184, 0, 0.3);
  border-radius: 24rpx;
  background: rgba(255, 184, 0, 0.1);
  color: #6b4c00;
  font-size: 24rpx;
  font-weight: 700;
}

.status-pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #666;
  font-size: 22rpx;
  font-weight: 700;
}

.toast {
  position: fixed;
  left: 80rpx;
  right: 80rpx;
  top: 80rpx;
  z-index: 99;
  padding: 20rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(34, 34, 34, 0.86);
  color: #ffffff;
  text-align: center;
  font-size: 26rpx;
}

.input,
.textarea {
  width: 100%;
  border-radius: 32rpx;
  background: #fff5e8;
  padding: 24rpx;
  box-sizing: border-box;
  color: #222;
}

.textarea {
  min-height: 260rpx;
}
