.upload-box {
  min-height: 720rpx;
  border: 4rpx dashed #ffb800;
  border-radius: 48rpx;
  background: #fff5e8;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.upload-box image {
  width: 100%;
  height: 720rpx;
}

.upload-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  border-radius: 999rpx;
  background: #ffb800;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  font-weight: 700;
}
