.design-page {
  min-height: 100vh;
  box-sizing: border-box;
  background: #f9f9f9;
  color: #222222;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.upload-main {
  padding: calc(env(safe-area-inset-top) + 176rpx) 40rpx 320rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.page-title {
  color: #1a1c1c;
  font-size: 48rpx;
  line-height: 64rpx;
  font-weight: 500;
}

.page-subtitle {
  margin-top: 16rpx;
  color: #666666;
  font-size: 28rpx;
  line-height: 40rpx;
}

.tips-card {
  padding: 32rpx;
  border-radius: 48rpx;
  display: flex;
  gap: 32rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(255, 184, 0, 0.05);
  box-sizing: border-box;
}

.example-card {
  position: relative;
  width: 220rpx;
  height: 300rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #eeeeee;
  flex: none;
}

.example-portrait {
  position: relative;
  width: 100%;
  height: 100%;
  background: linear-gradient(145deg, #ffe1c5 0%, #f7b68d 52%, #fff0db 100%);
}

.example-head {
  position: absolute;
  left: 50%;
  top: 54rpx;
  width: 96rpx;
  height: 112rpx;
  border-radius: 48rpx;
  transform: translateX(-50%);
  background: #f4c4a2;
  box-shadow: -34rpx -16rpx 0 18rpx #3b251e, 36rpx -14rpx 0 12rpx #2a1c17;
}

.example-shoulder {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 180rpx;
  height: 118rpx;
  border-radius: 80rpx 80rpx 0 0;
  transform: translateX(-50%);
  background: #fff6eb;
}

.example-label {
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  bottom: 12rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: rgba(249, 249, 249, 0.9);
  color: #222222;
  font-size: 24rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.mini-check {
  width: 24rpx;
  height: 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #26c26a;
  color: #ffffff;
  font-size: 18rpx;
}

.tips-list {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 32rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.tip-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffdbce;
  color: #7f2b00;
  font-size: 24rpx;
  flex: none;
}

.tip-title {
  color: #1a1c1c;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
}

.tip-desc {
  color: #666666;
  font-size: 24rpx;
  line-height: 32rpx;
}

.upload-box {
  min-height: 464rpx;
  border: 4rpx dashed #d5c4ab;
  border-radius: 48rpx;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f3f3;
}

.upload-preview {
  width: 100%;
  height: 464rpx;
  display: block;
}

.upload-empty {
  text-align: center;
}

.upload-icon {
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto 32rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 184, 0, 0.2);
  color: #ffb800;
  font-size: 46rpx;
}

.upload-title {
  color: #ffb800;
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 500;
}

.upload-desc {
  margin-top: 8rpx;
  color: #666666;
  font-size: 28rpx;
  line-height: 40rpx;
}

.upload-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 18;
  padding: 48rpx 40rpx calc(env(safe-area-inset-bottom) + 48rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  background: rgba(249, 249, 249, 0.92);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.02);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.action-primary,
.action-secondary,
.continue-button {
  width: 100%;
  height: 96rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #222222;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
}

.action-primary {
  background: #ffb800;
  box-shadow: 0 8rpx 12rpx rgba(255, 184, 0, 0.2);
}

.action-secondary {
  background: #ebe1d4;
}

.continue-button {
  background: #222222;
  color: #ffffff;
}

.action-primary::after,
.action-secondary::after,
.continue-button::after {
  border: 0;
}

.button-icon {
  font-size: 30rpx;
  font-weight: 700;
}

.resize-canvas {
  position: fixed;
  left: -2000px;
  top: -2000px;
  opacity: 0;
  pointer-events: none;
}
