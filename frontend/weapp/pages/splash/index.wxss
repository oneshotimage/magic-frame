.splash-page {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  justify-content: space-between;
  text-align: center;
}

.brand {
  padding-top: 64rpx;
  color: #1a1c1c;
  font-size: 32rpx;
  font-weight: 600;
}

.hero-card {
  position: relative;
  width: 680rpx;
  height: 850rpx;
  margin: 40rpx auto 0;
  overflow: hidden;
  border-radius: 64rpx;
  background: #fff5e8;
  box-shadow: 0 16rpx 48rpx rgba(255, 184, 0, 0.15);
}

.hero-img {
  width: 100%;
  height: 100%;
}

.css-portrait {
  position: relative;
  background:
    radial-gradient(circle at 22% 18%, rgba(255, 255, 255, 0.82), transparent 24%),
    linear-gradient(145deg, #fff8e7 0%, #ffb800 52%, #ffb599 100%);
}

.portrait-head {
  position: absolute;
  left: 50%;
  top: 180rpx;
  width: 210rpx;
  height: 210rpx;
  border-radius: 50%;
  transform: translateX(-50%);
  background: #fff3df;
  box-shadow: 0 -30rpx 0 34rpx rgba(90, 49, 30, 0.82);
}

.portrait-body {
  position: absolute;
  left: 50%;
  bottom: 170rpx;
  width: 390rpx;
  height: 260rpx;
  border-radius: 160rpx 160rpx 48rpx 48rpx;
  transform: translateX(-50%);
  background: rgba(255, 255, 255, 0.64);
}

.float-badge {
  position: absolute;
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #ff7d45;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.float-badge.left {
  left: -16rpx;
  top: 176rpx;
}

.float-badge.right {
  right: -16rpx;
  bottom: 360rpx;
  color: #ffb800;
}

.glass-panel {
  position: absolute;
  left: 48rpx;
  right: 48rpx;
  bottom: 48rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 34rpx;
  border-radius: 48rpx;
  background: rgba(255, 255, 255, 0.76);
  text-align: left;
}

.ai-dot {
  width: 80rpx;
  height: 80rpx;
  border-radius: 999rpx;
  background: #ffb800;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
}

.glass-title {
  font-size: 32rpx;
  font-weight: 700;
}

.bottom-copy {
  padding-bottom: 48rpx;
}
