.result-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.result-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
}

.result-card {
  overflow: hidden;
  border-radius: 36rpx;
  background: #ffffff;
  border: 1rpx solid rgba(213, 196, 171, 0.62);
}

.result-image {
  display: block;
  width: 100%;
  height: 320rpx;
  background: #fff5e8;
}

.result-name {
  padding: 18rpx 20rpx 22rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #222222;
}

.empty {
  text-align: left;
}
