.confirm-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 146rpx) 40rpx 220rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 184, 0, 0.12) 0, rgba(255, 184, 0, 0) 330rpx),
    #faf9f6;
  color: #222222;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.page-head {
  text-align: center;
}

.title {
  font-size: 48rpx;
  line-height: 66rpx;
  font-weight: 900;
}

.title text {
  color: #ffb800;
  font-size: 30rpx;
}

.subtitle {
  margin-top: 10rpx;
  color: #8a765a;
  font-size: 28rpx;
  line-height: 40rpx;
}

.photo-proof {
  margin-top: 28rpx;
  padding: 14rpx 14rpx 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 42rpx rgba(98, 64, 18, 0.1);
}

.proof-frame {
  position: relative;
  height: 610rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: #ead3b7;
}

.confirm-img {
  width: 100%;
  height: 100%;
  display: block;
}

.corner {
  position: absolute;
  width: 54rpx;
  height: 54rpx;
  border-color: #ffb800;
  border-style: solid;
}

.lt { left: 28rpx; top: 28rpx; border-width: 5rpx 0 0 5rpx; }
.rt { right: 28rpx; top: 28rpx; border-width: 5rpx 5rpx 0 0; }
.lb { left: 28rpx; bottom: 28rpx; border-width: 0 0 5rpx 5rpx; }
.rb { right: 28rpx; bottom: 28rpx; border-width: 0 5rpx 5rpx 0; }

.quality-badge {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  min-width: 210rpx;
  height: 82rpx;
  padding: 0 20rpx;
  border: 2rpx solid #ffb800;
  border-radius: 16rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: rgba(255, 255, 255, 0.92);
}

.badge-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffb800;
  color: #ffffff;
}

.badge-title {
  font-size: 25rpx;
  line-height: 32rpx;
  font-weight: 800;
}

.badge-desc {
  color: #756246;
  font-size: 22rpx;
  line-height: 28rpx;
}

.proof-sign {
  margin-top: 18rpx;
  color: rgba(141, 104, 45, 0.28);
  font-size: 36rpx;
  line-height: 48rpx;
  text-align: center;
  font-style: italic;
}

.quality-card,
.style-card {
  margin-top: 28rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(255, 184, 0, 0.22);
  border-radius: 28rpx;
  box-sizing: border-box;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(98, 64, 18, 0.06);
}

.card-title {
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 800;
}

.check-row {
  min-height: 78rpx;
  border-top: 1rpx solid rgba(213, 196, 171, 0.48);
  display: flex;
  align-items: center;
  gap: 18rpx;
  color: #222222;
  font-size: 29rpx;
}

.check-row:first-of-type {
  margin-top: 16rpx;
}

.check-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #b98400;
  color: #ffffff;
  font-weight: 800;
}

.check-status {
  margin-left: auto;
  color: #d59000;
}

.style-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.style-name {
  margin-top: 16rpx;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 800;
}

.style-desc {
  margin-top: 4rpx;
  color: #756246;
  font-size: 24rpx;
  line-height: 34rpx;
}

.edit-style,
.outline-btn {
  margin: 0;
  padding: 0;
  background: transparent;
}

.edit-style::after,
.outline-btn::after {
  border: 0;
}

.edit-style {
  color: #8a6322;
  font-size: 26rpx;
}

.bottom-actions {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(env(safe-area-inset-bottom) + 28rpx);
  z-index: 10;
  display: grid;
  grid-template-columns: 0.9fr 1.5fr;
  gap: 22rpx;
}

.outline-btn {
  height: 108rpx;
  border: 2rpx solid rgba(138, 99, 34, 0.45);
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  color: #222222;
  font-size: 32rpx;
  font-weight: 800;
}
