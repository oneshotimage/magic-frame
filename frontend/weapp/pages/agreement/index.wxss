.agreement-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 128rpx) 40rpx 330rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 184, 0, 0.12) 0, rgba(255, 184, 0, 0) 320rpx),
    #faf9f6;
  color: #222222;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.page-head {
  text-align: center;
}

.title {
  font-size: 52rpx;
  line-height: 70rpx;
  font-weight: 900;
}

.subtitle {
  margin-top: 12rpx;
  color: #77716a;
  font-size: 28rpx;
  line-height: 40rpx;
}

.task-card,
.consent-card,
.risk-card {
  margin-top: 34rpx;
  padding: 34rpx;
  border-radius: 34rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 38rpx rgba(98, 64, 18, 0.08);
}

.task-title {
  color: #222222;
  font-size: 34rpx;
  line-height: 46rpx;
  font-weight: 900;
}

.task-title text {
  color: #ffb800;
}

.task-body {
  margin-top: 28rpx;
  display: flex;
  gap: 28rpx;
}

.task-image {
  width: 230rpx;
  height: 270rpx;
  border-radius: 18rpx;
  flex: none;
  background: #f1d9b6;
}

.task-info {
  min-width: 0;
  flex: 1;
  padding-top: 12rpx;
}

.task-name {
  color: #222222;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.task-name text {
  margin-left: 12rpx;
  padding: 6rpx 14rpx;
  border-radius: 14rpx;
  background: #fff2d8;
  color: #b47700;
  font-size: 23rpx;
  font-weight: 600;
}

.task-line {
  margin-top: 18rpx;
  color: #666666;
  font-size: 27rpx;
  line-height: 36rpx;
}

.consent-card {
  padding: 0 34rpx;
}

.consent-row {
  min-height: 112rpx;
  border-bottom: 1rpx dashed rgba(213, 196, 171, 0.56);
  display: flex;
  align-items: center;
  gap: 24rpx;
  color: #222222;
  font-size: 30rpx;
  line-height: 42rpx;
}

.consent-row:last-child {
  border-bottom: 0;
}

.circle {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid #ffb800;
  border-radius: 50%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  flex: none;
}

.circle.checked {
  background: #ffb800;
}

.chevron {
  margin-left: auto;
  color: #b9a990;
  font-size: 42rpx;
}

.risk-card {
  display: flex;
  gap: 26rpx;
  background: linear-gradient(90deg, rgba(255, 246, 226, 0.94), rgba(255, 250, 241, 0.94));
}

.risk-icon {
  width: 92rpx;
  height: 92rpx;
  border: 3rpx solid rgba(255, 184, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #c58a00;
  flex: none;
}

.risk-title {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 900;
}

.risk-text {
  margin-top: 8rpx;
  color: #756246;
  font-size: 26rpx;
  line-height: 38rpx;
}

.bottom-actions {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(env(safe-area-inset-bottom) + 28rpx);
  z-index: 10;
}

.secondary-action {
  width: 100%;
  height: 96rpx;
  margin: 22rpx 0 0;
  padding: 0;
  border-radius: 24rpx;
  background: #ffffff;
  color: #222222;
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 28rpx rgba(98, 64, 18, 0.06);
}

.secondary-action::after {
  border: 0;
}

.safe-note {
  margin-top: 24rpx;
  color: #999999;
  font-size: 24rpx;
  line-height: 34rpx;
  text-align: center;
}
