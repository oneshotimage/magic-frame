.feedback-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 128rpx) 30rpx 210rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 88% 15%, rgba(255, 184, 0, 0.16), transparent 260rpx),
    #faf9f6;
  color: #222222;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.hero {
  position: relative;
  min-height: 190rpx;
  display: flex;
  align-items: center;
  gap: 26rpx;
}

.hero-icon {
  width: 86rpx;
  height: 86rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffe2a7;
  color: #1f1b13;
  font-size: 46rpx;
  box-shadow: 0 12rpx 26rpx rgba(255, 184, 0, 0.18);
}

.title {
  font-size: 54rpx;
  line-height: 72rpx;
  font-weight: 900;
}

.subtitle {
  color: #7c5800;
  font-size: 30rpx;
  line-height: 42rpx;
}

.mail-illus {
  position: absolute;
  right: -8rpx;
  top: 8rpx;
  width: 190rpx;
  height: 150rpx;
  opacity: 0.7;
}

.mail-illus::before {
  content: "";
  position: absolute;
  left: 28rpx;
  bottom: 0;
  width: 150rpx;
  height: 94rpx;
  border-radius: 14rpx;
  background: #f1d8a9;
  transform: rotate(8deg);
}

.paper {
  position: absolute;
  left: 44rpx;
  top: 0;
  width: 112rpx;
  height: 120rpx;
  border-radius: 10rpx;
  background: #fff7e9;
  transform: rotate(8deg);
}

.card,
.contact-row {
  margin-top: 26rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 32rpx rgba(98, 64, 18, 0.07);
}

.card-title {
  font-size: 31rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.chip-row {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.chip {
  height: 74rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(213, 196, 171, 0.62);
  border-radius: 18rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #222222;
  font-size: 28rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.8);
}

.chip.active {
  border-color: #ffb800;
  background: #fff6df;
  color: #7c5800;
}

.textarea {
  width: 100%;
  height: 300rpx;
  margin-top: 22rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(213, 196, 171, 0.62);
  border-radius: 20rpx;
  box-sizing: border-box;
  background: #fffdf8;
  color: #222222;
  font-size: 28rpx;
  line-height: 42rpx;
}

.count {
  margin-top: -42rpx;
  padding-right: 24rpx;
  color: #9a9a9a;
  font-size: 24rpx;
  line-height: 34rpx;
  text-align: right;
}

.contact-row {
  min-height: 94rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.contact-icon {
  font-size: 40rpx;
}

.contact-label {
  color: #222222;
  font-size: 29rpx;
  font-weight: 800;
  white-space: nowrap;
}

.contact-input {
  min-width: 0;
  flex: 1;
  color: #222222;
  font-size: 28rpx;
  text-align: right;
}

.chevron {
  color: #9a9a9a;
  font-size: 42rpx;
}

.upload-card {
  min-height: 240rpx;
}

.upload-tile {
  width: 160rpx;
  height: 160rpx;
  margin-top: 24rpx;
  border: 2rpx dashed rgba(180, 119, 0, 0.32);
  border-radius: 16rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8a6322;
  font-size: 25rpx;
}

.camera-icon {
  font-size: 44rpx;
  line-height: 46rpx;
}

.upload-tile text {
  margin-top: 4rpx;
  color: #9a9a9a;
  font-size: 21rpx;
}

.bottom-action {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: calc(env(safe-area-inset-bottom) + 28rpx);
  z-index: 10;
}

.safe-note {
  margin-top: 18rpx;
  color: #756246;
  font-size: 24rpx;
  line-height: 34rpx;
  text-align: center;
}
