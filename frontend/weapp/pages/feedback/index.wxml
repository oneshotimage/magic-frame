<view class="page stack">
  <view>
    <view class="title">意见反馈</view>
    <view class="subtitle">描述你遇到的问题或希望增加的功能。</view>
  </view>

  <textarea class="textarea" maxlength="800" value="{{content}}" bindinput="onContentInput" placeholder="请输入反馈内容" />
  <input class="input" value="{{contact}}" bindinput="onContactInput" placeholder="联系方式（选填）" />
  <app-button text="提交反馈" loading="{{submitting}}" bind:press="submit" />
</view>
