.progress-track {
  height: 18rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #fff5e8;
}

.progress-track view {
  height: 100%;
  border-radius: 999rpx;
  background: #ffb800;
}

.provider-line {
  margin-top: 16rpx;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step {
  padding: 24rpx;
  border-radius: 36rpx;
  background: #fff5e8;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
}

.step-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.step-error,
.step-debug {
  max-width: 460rpx;
  color: #ba1a1a;
  font-size: 22rpx;
  line-height: 32rpx;
  word-break: break-all;
}

.step-debug {
  color: #666666;
}
