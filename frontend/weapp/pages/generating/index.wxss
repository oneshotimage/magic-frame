.design-page {
  min-height: 100vh;
  box-sizing: border-box;
  background: #f9f9f9;
  color: #222222;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
  overflow: hidden;
}

.design-topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  height: 96rpx;
  padding: 0 40rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(249, 249, 249, 0.82);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.nav-symbol {
  width: 96rpx;
  color: #7c5800;
  font-size: 48rpx;
  line-height: 48rpx;
  font-weight: 500;
}

.nav-more {
  font-size: 28rpx;
  text-align: right;
  letter-spacing: 3rpx;
}

.nav-title {
  color: #1a1c1c;
  font-size: 38rpx;
  line-height: 52rpx;
  font-weight: 500;
  text-align: center;
  white-space: nowrap;
}

.glow {
  position: fixed;
  border-radius: 999rpx;
  pointer-events: none;
}

.glow-main {
  left: 50%;
  top: 358rpx;
  width: 600rpx;
  height: 600rpx;
  margin-left: -300rpx;
  background: rgba(255, 184, 0, 0.16);
  filter: blur(64rpx);
}

.glow-side {
  left: 190rpx;
  top: 684rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 179, 149, 0.24);
  filter: blur(40rpx);
}

.stage {
  position: relative;
  z-index: 2;
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 604rpx) 40rpx 420rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.progress-shell {
  position: relative;
  width: 512rpx;
  height: 512rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-back,
.ring-front {
  position: absolute;
  inset: 0;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.ring-back {
  border: 30rpx solid rgba(255, 184, 0, 0.2);
}

.ring-front {
  border: 30rpx solid #ffb800;
  clip-path: polygon(50% 0, 100% 0, 100% 100%, 50% 100%);
  transform-origin: center;
}

.avatar-wrap {
  width: 384rpx;
  height: 384rpx;
  padding: 8rpx;
  border: 8rpx solid #ffffff;
  border-radius: 999rpx;
  box-sizing: border-box;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 16rpx 48rpx rgba(255, 184, 0, 0.15);
}

.avatar-css {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 999rpx;
  overflow: hidden;
  background: linear-gradient(150deg, #fff1ce 0%, #d9b27d 52%, #f5e1c3 100%);
}

.avatar-hair {
  position: absolute;
  left: 50%;
  top: 50rpx;
  width: 236rpx;
  height: 250rpx;
  border-radius: 120rpx 120rpx 90rpx 90rpx;
  transform: translateX(-50%);
  background: #b78b56;
  box-shadow: -54rpx 20rpx 0 -8rpx #cfa86e, 52rpx 18rpx 0 -6rpx #8b673f;
}

.avatar-face {
  position: absolute;
  left: 50%;
  top: 124rpx;
  width: 154rpx;
  height: 170rpx;
  border-radius: 80rpx 80rpx 70rpx 70rpx;
  transform: translateX(-50%);
  background: #f2c9ad;
}

.avatar-body {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 246rpx;
  height: 116rpx;
  border-radius: 120rpx 120rpx 0 0;
  transform: translateX(-50%);
  background: #fff9ec;
}

.shimmer {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.45) 50%, transparent 100%);
  opacity: 0.7;
}

.sparkle-main {
  position: absolute;
  right: 64rpx;
  top: 32rpx;
  color: #ffb800;
  font-size: 64rpx;
}

.sparkle-small {
  position: absolute;
  left: 64rpx;
  bottom: 80rpx;
  color: #ffdbce;
  font-size: 40rpx;
}

.percent-row {
  margin-top: 48rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
  color: #222222;
}

.percent-number {
  font-size: 56rpx;
  line-height: 72rpx;
  font-weight: 800;
}

.percent-mark {
  margin-left: 8rpx;
  font-size: 48rpx;
  line-height: 64rpx;
  font-weight: 700;
}

.generating-title {
  margin-top: 16rpx;
  color: #222222;
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 500;
  text-align: center;
}

.elapsed-row {
  margin-top: 18rpx;
  min-width: 216rpx;
  height: 64rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(255, 184, 0, 0.12);
}

.remaining-row {
  margin-top: 12rpx;
  background: rgba(255, 255, 255, 0.72);
}

.elapsed-label {
  color: #666666;
  font-size: 24rpx;
  line-height: 34rpx;
}

.elapsed-value {
  color: #7c5800;
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 700;
}

.generating-subtitle {
  margin-top: 16rpx;
  color: #666666;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

.tips-panel {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: 150rpx;
  z-index: 4;
  min-height: 80rpx;
  padding: 34rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.05);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.tips-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(235, 225, 212, 0.3);
  font-size: 32rpx;
  flex: none;
}

.tips-text {
  min-width: 0;
  color: #514532;
  font-size: 28rpx;
  line-height: 40rpx;
}

.provider-panel {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: 268rpx;
  z-index: 5;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(34, 34, 34, 0.72);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 32rpx;
}

.bottom-actions {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  z-index: 6;
  display: flex;
  gap: 20rpx;
}

.ghost-button {
  flex: 1;
  height: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: rgba(235, 225, 212, 0.78);
  color: #645e54;
  font-size: 24rpx;
  line-height: 34rpx;
}

.ghost-button::after {
  border: 0;
}
