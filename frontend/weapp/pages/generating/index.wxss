.generating-page {
  position: relative;
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 128rpx) 40rpx 174rpx;
  box-sizing: border-box;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(255, 184, 0, 0.08) 0%, rgba(255, 184, 0, 0) 310rpx),
    #faf9f6;
  color: #222222;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.page-grid {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  pointer-events: none;
  opacity: 0.34;
  background-image:
    linear-gradient(rgba(124, 88, 0, 0.055) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(124, 88, 0, 0.055) 1rpx, transparent 1rpx);
  background-size: 48rpx 48rpx;
}

.main {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.visual-panel {
  padding: 30rpx 30rpx 32rpx;
  border: 1rpx solid rgba(255, 184, 0, 0.22);
  border-radius: 32rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 18rpx 48rpx rgba(92, 64, 12, 0.08);
  -webkit-backdrop-filter: blur(16rpx);
  backdrop-filter: blur(16rpx);
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.eyebrow {
  color: #9a741f;
  font-size: 20rpx;
  line-height: 28rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.panel-title {
  margin-top: 4rpx;
  color: #222222;
  font-size: 38rpx;
  line-height: 52rpx;
  font-weight: 800;
}

.live-pill {
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(255, 184, 0, 0.14);
  color: #7c5800;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 700;
  white-space: nowrap;
}

.live-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ffb800;
  animation: pulse 1.5s ease-in-out infinite;
}

.photo-stage {
  position: relative;
  height: 520rpx;
  margin-top: 20rpx;
}

.photo-card {
  position: absolute;
  left: 50%;
  width: 416rpx;
  height: 456rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  transform: translateX(-50%);
}

.photo-card-back {
  top: 42rpx;
  background: #fff1d4;
  transform: translateX(-50%) rotate(-7deg);
}

.photo-card-mid {
  top: 28rpx;
  background: #ffe3b5;
  box-shadow: 0 18rpx 42rpx rgba(161, 111, 20, 0.1);
  transform: translateX(-50%) rotate(5deg);
}

.photo-card-main {
  top: 0;
  padding: 22rpx;
  overflow: hidden;
  border: 10rpx solid #ffffff;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.78) 0%, rgba(255, 245, 224, 0.3) 100%),
    #f8d7ae;
  box-shadow: 0 22rpx 60rpx rgba(78, 50, 10, 0.16);
}

.corner {
  position: absolute;
  z-index: 4;
  width: 42rpx;
  height: 42rpx;
  border-color: rgba(255, 184, 0, 0.92);
  border-style: solid;
}

.corner-lt {
  left: 24rpx;
  top: 24rpx;
  border-width: 4rpx 0 0 4rpx;
}

.corner-rt {
  right: 24rpx;
  top: 24rpx;
  border-width: 4rpx 4rpx 0 0;
}

.corner-lb {
  left: 24rpx;
  bottom: 24rpx;
  border-width: 0 0 4rpx 4rpx;
}

.corner-rb {
  right: 24rpx;
  bottom: 24rpx;
  border-width: 0 4rpx 4rpx 0;
}

.portrait {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  top: 22rpx;
  bottom: 22rpx;
  overflow: hidden;
  border-radius: 20rpx;
  background:
    linear-gradient(150deg, rgba(255, 249, 235, 0.95) 0%, rgba(240, 200, 151, 0.82) 52%, rgba(255, 238, 214, 0.92) 100%);
}

.preview-image {
  width: 100%;
  height: 100%;
  display: block;
}

.portrait-highlight {
  position: absolute;
  z-index: 1;
  left: 64rpx;
  top: 40rpx;
  width: 132rpx;
  height: 420rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.38) 0%, rgba(255, 255, 255, 0) 100%);
  transform: rotate(18deg);
}

.scan-line {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  top: 28rpx;
  z-index: 3;
  height: 74rpx;
  border-top: 2rpx solid rgba(255, 184, 0, 0.82);
  border-bottom: 2rpx solid rgba(255, 184, 0, 0.22);
  background: linear-gradient(180deg, rgba(255, 184, 0, 0.18) 0%, rgba(255, 255, 255, 0) 100%);
  animation: scan 2.8s ease-in-out infinite;
}

.grain-layer {
  position: absolute;
  inset: 0;
  z-index: 2;
  opacity: 0.34;
  background-image:
    radial-gradient(circle, rgba(255, 255, 255, 0.42) 1rpx, transparent 1rpx);
  background-size: 18rpx 18rpx;
}

.ai-chip {
  position: absolute;
  right: 98rpx;
  bottom: 18rpx;
  z-index: 5;
  width: 94rpx;
  height: 94rpx;
  border: 8rpx solid #ffffff;
  border-radius: 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #222222;
  color: #ffb800;
  font-size: 34rpx;
  line-height: 42rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 28rpx rgba(34, 34, 34, 0.18);
}

.progress-block {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.progress-copy {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
}

.percent-row {
  display: flex;
  align-items: baseline;
  color: #222222;
}

.percent-number {
  font-size: 62rpx;
  line-height: 74rpx;
  font-weight: 900;
}

.percent-mark {
  margin-left: 6rpx;
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 800;
}

.generating-subtitle {
  min-width: 0;
  padding-bottom: 9rpx;
  color: #756246;
  font-size: 24rpx;
  line-height: 34rpx;
  text-align: right;
  white-space: nowrap;
}

.progress-track {
  height: 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(122, 88, 0, 0.12);
}

.progress-fill {
  height: 100%;
  min-width: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ffb800 0%, #ff8f3d 100%);
  transition: width 240ms ease;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.time-card {
  min-height: 124rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(92, 64, 12, 0.06);
}

.time-label {
  color: #82725d;
  font-size: 23rpx;
  line-height: 32rpx;
  font-weight: 500;
}

.time-value {
  margin-top: 8rpx;
  color: #7c5800;
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 800;
}

.pipeline-card {
  min-height: 104rpx;
  padding: 22rpx 20rpx;
  border-radius: 26rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(92, 64, 12, 0.06);
}

.pipeline-item {
  min-width: 0;
  flex: 1 1 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  color: #9a8c78;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 600;
  white-space: nowrap;
}

.pipeline-dot {
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid rgba(154, 140, 120, 0.24);
  border-radius: 50%;
  box-sizing: border-box;
  background: #ffffff;
}

.pipeline-item.done,
.pipeline-item.active {
  color: #7c5800;
}

.pipeline-item.done .pipeline-dot {
  border-color: #ffb800;
  background: #ffb800;
}

.pipeline-item.active .pipeline-dot {
  border-color: #ffb800;
  box-shadow: 0 0 0 8rpx rgba(255, 184, 0, 0.16);
}

.pipeline-line {
  width: 46rpx;
  height: 2rpx;
  margin-top: -28rpx;
  flex: none;
  background: rgba(154, 140, 120, 0.22);
}

.tips-panel {
  min-height: 88rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: rgba(255, 248, 232, 0.92);
  color: #514532;
}

.tips-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffb800;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 24rpx;
  flex: none;
}

.tips-text {
  min-width: 0;
  font-size: 26rpx;
  line-height: 38rpx;
  font-weight: 500;
}

.provider-panel {
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(34, 34, 34, 0.72);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 32rpx;
}

.bottom-actions {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  z-index: 6;
  display: flex;
  gap: 20rpx;
}

.ghost-button {
  flex: 1;
  height: 82rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 36rpx;
  font-weight: 700;
}

.ghost-button::after {
  border: 0;
}

.ghost-button.danger {
  background: rgba(255, 255, 255, 0.86);
  color: #8d6d2a;
}

.ghost-button.primary {
  background: #222222;
  color: #ffffff;
}

@keyframes scan {
  0% {
    transform: translateY(0);
    opacity: 0.35;
  }
  45% {
    opacity: 0.92;
  }
  100% {
    transform: translateY(334rpx);
    opacity: 0.35;
  }
}

@keyframes pulse {
  0%,
  100% {
    transform: scale(0.82);
    opacity: 0.55;
  }
  50% {
    transform: scale(1);
    opacity: 1;
  }
}
