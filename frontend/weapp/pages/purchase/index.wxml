<view class="design-page purchase-page">
  <view class="warm-bg"></view>
  <nav-bar title="妙影工坊" bind:back="goBack" />

  <view class="purchase-main">
    <view class="balance-card">
      <view class="balance-label">
        <text class="star-dot">✦</text>
        <text>当前可用算力</text>
      </view>
      <view class="balance-value">
        <text>{{creditText}}</text>
        <text class="balance-unit">次</text>
      </view>
    </view>

    <view class="section-title">选择充值套餐</view>
    <view class="package-list">
      <view wx:for="{{packages}}" wx:key="packageId" class="package-card {{selectedPackageId === item.packageId ? 'selected' : ''}}" bindtap="selectPackage" data-id="{{item.packageId}}">
        <view wx:if="{{item.packageId === popularPackageId}}" class="popular-badge">最受欢迎</view>
        <view wx:if="{{selectedPackageId === item.packageId}}" class="checkmark">✓</view>
        <view>
          <view class="credit-row">
            <text class="package-count">{{item.credits}}</text>
            <text class="package-unit">次生成</text>
          </view>
          <view wx:if="{{item.note}}" class="package-note">{{item.note}}</view>
        </view>
        <view class="package-price">¥ {{item.priceYuan}}</view>
      </view>
    </view>

    <view class="trust-banner">
      <view class="trust-item">
        <view class="trust-icon">⚡</view>
        <view>极速出图</view>
      </view>
      <view class="trust-divider"></view>
      <view class="trust-item">
        <view class="trust-icon">▿</view>
        <view>安全支付</view>
      </view>
      <view class="trust-divider"></view>
      <view class="trust-item">
        <view class="trust-icon">↺</view>
        <view>长期有效</view>
      </view>
    </view>

    <view wx:if="{{order}}" class="order-card">
      <view class="order-title">待支付订单</view>
      <view class="order-id">订单号：{{order.orderId}}</view>
      <view class="order-price">¥ {{orderPriceText}}</view>
      <view class="order-actions">
        <app-button text="模拟微信支付成功" icon="" variant="compact" bind:press="payOrder" />
        <button class="close-button" bindtap="closeOrder">关闭订单</button>
      </view>
    </view>
  </view>

  <view class="purchase-bottom">
    <app-button text="立即购买  ¥ {{selectedPriceText}}" icon="" bind:press="buySelected" />
  </view>
</view>
