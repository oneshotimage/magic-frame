<view class="page stack">
  <view>
    <view class="title">购买生成次数</view>
    <view class="subtitle">当前剩余 {{creditText}} 次</view>
  </view>

  <view class="package-list">
    <view wx:for="{{packages}}" wx:key="packageId" class="package-card" bindtap="createOrder" data-id="{{item.packageId}}">
      <view>
        <view class="package-name">{{item.name}}</view>
        <view class="muted">{{item.credits}} 次生成额度</view>
      </view>
      <view class="package-price">¥{{item.priceFen / 100}}</view>
    </view>
  </view>

  <view wx:if="{{order}}" class="card stack">
    <view class="title">待支付订单</view>
    <view class="muted">订单号：{{order.orderId}}</view>
    <view class="package-price">¥{{order.amountFen / 100}}</view>
    <button class="primary-btn" bindtap="payOrder">模拟微信支付成功</button>
    <button class="secondary-btn" bindtap="closeOrder">关闭订单</button>
  </view>
</view>
