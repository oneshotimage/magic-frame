.design-page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  background: #f9f9f9;
  color: #222222;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.warm-bg {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  height: 768rpx;
  background: linear-gradient(180deg, rgba(255, 222, 168, 0.3), rgba(255, 222, 168, 0));
  pointer-events: none;
}

.design-topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  height: 96rpx;
  padding: 0 40rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(249, 249, 249, 0.82);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.nav-symbol {
  width: 88rpx;
  color: #7c5800;
  font-size: 48rpx;
  line-height: 48rpx;
  font-weight: 500;
}

.nav-more {
  font-size: 28rpx;
  text-align: right;
  letter-spacing: 3rpx;
}

.nav-title {
  color: #1a1c1c;
  font-size: 38rpx;
  line-height: 52rpx;
  font-weight: 500;
  white-space: nowrap;
}

.purchase-main {
  position: relative;
  z-index: 1;
  padding: 160rpx 40rpx 260rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.balance-card {
  min-height: 220rpx;
  padding: 48rpx;
  border-radius: 48rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 48rpx rgba(255, 184, 0, 0.1);
  overflow: hidden;
}

.balance-label {
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: #514532;
  font-size: 28rpx;
  line-height: 40rpx;
}

.star-dot {
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffb800;
  color: #ffffff;
  font-size: 22rpx;
}

.balance-value {
  margin-top: 16rpx;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  color: #222222;
  font-size: 56rpx;
  line-height: 72rpx;
  font-weight: 800;
}

.balance-unit {
  color: #666666;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 500;
}

.section-title {
  color: #1a1c1c;
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 500;
}

.package-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.package-card {
  position: relative;
  min-height: 156rpx;
  padding: 46rpx;
  border: 6rpx solid transparent;
  border-radius: 48rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  box-shadow: 0 16rpx 24rpx rgba(255, 184, 0, 0.1);
}

.package-card.selected {
  border-color: #ffb800;
}

.popular-badge {
  position: absolute;
  left: 48rpx;
  top: -24rpx;
  padding: 10rpx 26rpx;
  border: 2rpx solid #ffffff;
  border-radius: 999rpx;
  background: #ffdbce;
  color: #7f2b00;
  font-size: 24rpx;
  line-height: 32rpx;
  box-shadow: 0 2rpx 2rpx rgba(0, 0, 0, 0.05);
}

.checkmark {
  position: absolute;
  right: -24rpx;
  top: -24rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffb800;
  color: #222222;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 12rpx rgba(0, 0, 0, 0.1);
}

.credit-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.package-count {
  color: #222222;
  font-size: 48rpx;
  line-height: 64rpx;
  font-weight: 700;
}

.package-unit {
  color: #666666;
  font-size: 28rpx;
  line-height: 40rpx;
}

.package-note {
  margin-top: 8rpx;
  color: #7c5800;
  font-size: 24rpx;
  line-height: 32rpx;
}

.package-price {
  color: #7c5800;
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 700;
}

.trust-banner {
  margin-top: 16rpx;
  padding: 32rpx 48rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f3f3f3;
}

.trust-item {
  min-width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: #514532;
  font-size: 24rpx;
  line-height: 32rpx;
}

.trust-icon {
  color: #ffb800;
  font-size: 36rpx;
  line-height: 40rpx;
}

.trust-divider {
  width: 2rpx;
  height: 64rpx;
  background: rgba(213, 196, 171, 0.3);
}

.order-card {
  padding: 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.06);
}

.order-title {
  color: #222222;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 700;
}

.order-id {
  margin-top: 8rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 36rpx;
}

.order-price {
  margin-top: 16rpx;
  color: #7c5800;
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 800;
}

.order-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 20rpx;
}

.pay-button,
.close-button {
  flex: 1;
  height: 80rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  line-height: 36rpx;
}

.pay-button {
  background: #ffb800;
  color: #222222;
}

.close-button {
  background: #f3f3f3;
  color: #645e54;
}

.pay-button::after,
.close-button::after,
.buy-button::after {
  border: 0;
}

.purchase-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 18;
  padding: 34rpx 40rpx calc(env(safe-area-inset-bottom) + 34rpx);
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 -8rpx 48rpx rgba(0, 0, 0, 0.03);
  -webkit-backdrop-filter: blur(16rpx);
  backdrop-filter: blur(16rpx);
}

.buy-button {
  width: 100%;
  height: 120rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #ffb800;
  color: #222222;
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 500;
  box-shadow: 0 16rpx 24rpx rgba(255, 184, 0, 0.22);
}

.buy-price {
  font-weight: 800;
}
