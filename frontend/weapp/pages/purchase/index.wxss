.package-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.package-card {
  min-height: 148rpx;
  padding: 32rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  border: 1rpx solid rgba(213, 196, 171, 0.62);
  box-sizing: border-box;
}

.package-name,
.package-price {
  font-size: 34rpx;
  font-weight: 800;
  color: #222222;
}
