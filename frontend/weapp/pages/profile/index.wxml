<view class="profile-page">
  <nav-bar title="AI影像写真馆" bind:back="goBack" />

  <view wx:if="{{!loggedIn}}" class="guest-main">
    <view class="guest-profile-row" bindtap="goLogin">
      <view class="guest-avatar-image">
        <text class="guest-avatar-icon">♟</text>
      </view>
      <view class="guest-copy-wrap">
        <view class="guest-title">点击登录/注册</view>
        <view class="guest-copy">登录后体验更多AI写真功能</view>
      </view>
      <text class="guest-chevron">›</text>
    </view>

    <view class="guest-balance-card">
      <view class="guest-balance-left">
        <view class="guest-balance-icon">✦</view>
        <view>
          <view class="guest-balance-title">剩余生成次数</view>
          <view class="guest-balance-desc">登录查看剩余次数</view>
        </view>
      </view>
      <app-button text="去充值" icon="" variant="mini" bind:press="goPurchase" />
    </view>

    <view class="guest-menu-card">
      <view class="guest-menu-row" bindtap="goOrders">
        <view class="guest-menu-left"><text class="guest-menu-icon">▤</text><text>购买记录</text></view>
        <text class="chevron">›</text>
      </view>
      <view class="guest-menu-row" bindtap="goWorks">
        <view class="guest-menu-left"><text class="guest-menu-icon">↺</text><text>作品历史</text></view>
        <text class="chevron">›</text>
      </view>
      <view class="guest-menu-row" bindtap="goGuide">
        <view class="guest-menu-left"><text class="guest-menu-icon">▰</text><text>使用指南</text></view>
        <text class="chevron">›</text>
      </view>
      <view class="guest-menu-row last" bindtap="goFaq">
        <view class="guest-menu-left"><text class="guest-menu-icon">?</text><text>常见问题</text></view>
        <text class="chevron">›</text>
      </view>
    </view>
  </view>

  <block wx:else>
    <view class="main">
      <view class="profile-card">
        <view class="avatar-shell">
          <image wx:if="{{user && user.avatarUrl}}" class="avatar" mode="aspectFill" src="{{user.avatarUrl}}" />
          <view wx:else class="avatar avatar-fallback">AI</view>
        </view>
        <view class="identity">
          <view class="profile-name">{{(user && user.nickname) || '张小光影'}}</view>
          <view class="profile-id">ID: {{userIdText || '8839201'}}</view>
        </view>
        <button class="edit-button" bindtap="editProfile" aria-label="编辑资料">
          <text class="edit-icon">✎</text>
        </button>
      </view>

      <view class="credits-card">
        <view class="glow glow-top"></view>
        <view class="glow glow-bottom"></view>
        <view class="credits-copy">
          <view class="credits-label">当前剩余点数</view>
          <view class="credits-row">
            <text class="credits-value">{{creditText || '5'}}</text>
            <text class="credit-icon">✦</text>
          </view>
        </view>
        <app-button text="去充值" icon="" variant="mini" bind:press="goPurchase" />
      </view>

      <view class="section">
        <view class="section-title">常用功能</view>
        <view class="menu-card">
          <view class="menu-row bordered" bindtap="goOrders">
            <view class="menu-left">
              <view class="action-icon-shell">
                <text class="orders-icon">▣</text>
              </view>
              <view class="menu-text">购买记录</view>
            </view>
            <text class="chevron">›</text>
          </view>
          <view class="menu-row" bindtap="goWorks">
            <view class="menu-left">
              <view class="action-icon-shell">
                <text class="works-icon">↺</text>
              </view>
              <view class="menu-text">作品历史</view>
            </view>
            <text class="chevron">›</text>
          </view>
        </view>
      </view>

      <view class="section about-section">
        <view class="section-title">关于</view>
        <view class="menu-card">
          <view class="menu-row bordered" bindtap="goFaq">
            <view class="menu-left">
              <view class="about-icon-shell">
                <text class="about-icon">?</text>
              </view>
              <view class="menu-text">常见问题</view>
            </view>
            <text class="chevron">›</text>
          </view>
          <view class="menu-row bordered" bindtap="goPrivacy">
            <view class="menu-left">
              <view class="about-icon-shell">
                <text class="privacy-icon">i</text>
              </view>
              <view class="menu-text">隐私政策</view>
            </view>
            <text class="chevron">›</text>
          </view>
          <view class="menu-row" bindtap="goLegal">
            <view class="menu-left">
              <view class="about-icon-shell">
                <text class="privacy-icon">□</text>
              </view>
              <view class="menu-text">用户协议</view>
            </view>
            <text class="chevron">›</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <app-tabbar active="profile" />
</view>
