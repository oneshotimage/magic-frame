<view class="profile-page">
  <view class="top-bar">
    <button class="bar-button" bindtap="goBack">
      <text class="back-icon">‹</text>
    </button>
    <view class="bar-title">AI影像写真馆</view>
    <button class="bar-button more-button">
      <text class="more-icon">•••</text>
    </button>
  </view>

  <view wx:if="{{!loggedIn}}" class="guest-hero">
    <view class="guest-avatar-image avatar-fallback">AI</view>
    <view class="guest-title">登录后查看我的</view>
    <view class="guest-copy">同步作品、订单和生成额度，继续保存你的 AI 写真记录。</view>
    <button class="login-cta" bindtap="goLogin">微信登录</button>
  </view>

  <block wx:else>
    <view class="main">
      <view class="profile-card">
        <view class="avatar-shell">
          <image wx:if="{{user && user.avatarUrl}}" class="avatar" mode="aspectFill" src="{{user.avatarUrl}}" />
          <view wx:else class="avatar avatar-fallback">AI</view>
        </view>
        <view class="identity">
          <view class="profile-name">{{(user && user.nickname) || '张小光影'}}</view>
          <view class="profile-id">ID: {{userIdText || '8839201'}}</view>
        </view>
        <button class="edit-button" bindtap="editProfile" aria-label="编辑资料">
          <text class="edit-icon">✎</text>
        </button>
      </view>

      <view class="credits-card">
        <view class="glow glow-top"></view>
        <view class="glow glow-bottom"></view>
        <view class="credits-copy">
          <view class="credits-label">当前剩余点数</view>
          <view class="credits-row">
            <text class="credits-value">{{creditText || '5'}}</text>
            <text class="credit-icon">✦</text>
          </view>
        </view>
        <button class="recharge-button" bindtap="goPurchase">去充值</button>
      </view>

      <view class="section">
        <view class="section-title">常用功能</view>
        <view class="menu-card">
          <view class="menu-row bordered" bindtap="goOrders">
            <view class="menu-left">
              <view class="action-icon-shell">
                <text class="orders-icon">▣</text>
              </view>
              <view class="menu-text">购买记录</view>
            </view>
            <text class="chevron">›</text>
          </view>
          <view class="menu-row" bindtap="goWorks">
            <view class="menu-left">
              <view class="action-icon-shell">
                <text class="works-icon">↺</text>
              </view>
              <view class="menu-text">作品历史</view>
            </view>
            <text class="chevron">›</text>
          </view>
        </view>
      </view>

      <view class="section about-section">
        <view class="section-title">关于</view>
        <view class="menu-card">
          <view class="menu-row bordered" bindtap="goFaq">
            <view class="menu-left">
              <view class="about-icon-shell">
                <text class="about-icon">?</text>
              </view>
              <view class="menu-text">常见问题</view>
            </view>
            <text class="chevron">›</text>
          </view>
          <view class="menu-row bordered" bindtap="goLegal">
            <view class="menu-left">
              <view class="about-icon-shell">
                <text class="privacy-icon">i</text>
              </view>
              <view class="menu-text">隐私政策</view>
            </view>
            <text class="chevron">›</text>
          </view>
          <view class="menu-row" bindtap="goLegal">
            <view class="menu-left">
              <view class="about-icon-shell">
                <text class="privacy-icon">□</text>
              </view>
              <view class="menu-text">用户协议</view>
            </view>
            <text class="chevron">›</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <view class="bottom-nav">
    <view class="tab-item" bindtap="goHome">
      <text class="tab-icon home-tab">⌂</text>
      <view class="tab-label">首页</view>
    </view>
    <view class="tab-item" bindtap="goWorks">
      <text class="tab-icon works-tab">▧</text>
      <view class="tab-label">作品集</view>
    </view>
    <view class="tab-item active">
      <text class="tab-icon mine-tab">♙</text>
      <view class="tab-label active-label">我的</view>
    </view>
  </view>
</view>
