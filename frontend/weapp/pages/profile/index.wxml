<view class="page safe-tab stack">
  <view wx:if="{{!loggedIn}}" class="login-empty card stack">
    <view class="title">登录后查看我的</view>
    <view class="subtitle">同步作品、订单和生成额度，继续保存你的 AI 写真记录。</view>
    <button class="primary-btn" bindtap="goLogin">微信登录</button>
  </view>

  <block wx:else>
  <view class="profile-card">
    <image class="avatar" mode="aspectFill" src="{{avatarImage}}" />
    <view class="profile-main">
      <view class="title">{{user.nickname || '微信用户'}}</view>
      <view class="subtitle">剩余 {{creditText}} 次生成额度</view>
    </view>
  </view>

  <button class="primary-btn" bindtap="goPurchase">购买生成次数</button>

  <view class="menu">
    <view class="menu-item" bindtap="editProfile">编辑资料</view>
    <view class="menu-item" bindtap="goWorks">我的作品</view>
    <view class="menu-item" bindtap="goOrders">订单记录</view>
    <view class="menu-item" bindtap="goFaq">常见问题</view>
    <view class="menu-item" bindtap="goLegal">隐私与协议</view>
    <view class="menu-item" bindtap="goFeedback">意见反馈</view>
  </view>

  <button class="secondary-btn" bindtap="logout">退出登录</button>
  <button class="danger-btn" bindtap="deleteUser">删除账号</button>
  </block>
</view>
