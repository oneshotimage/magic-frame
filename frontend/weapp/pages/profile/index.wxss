.profile-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 124rpx) 34rpx 190rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 86% 8%, rgba(255, 184, 0, 0.18), transparent 260rpx),
    radial-gradient(circle at 0% 36%, rgba(255, 219, 139, 0.16), transparent 300rpx),
    linear-gradient(180deg, #fffdf9 0%, #faf7ef 54%, #fffdf9 100%);
  color: #222222;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.edit-button::after,
.login-cta::after,
.logout-button::after {
  border: 0;
}

.main {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding-top: 16rpx;
}

.profile-hero {
  position: relative;
  min-height: 150rpx;
  padding: 0 10rpx;
  box-sizing: border-box;
}

.profile-hero::after {
  content: "";
  position: absolute;
  right: -24rpx;
  top: -12rpx;
  width: 260rpx;
  height: 150rpx;
  border-radius: 40rpx;
  opacity: 0.5;
  background:
    radial-gradient(circle at 68% 38%, rgba(255, 184, 0, 0.3), transparent 22%),
    linear-gradient(150deg, transparent 24%, rgba(126, 96, 47, 0.16) 25%, transparent 27%),
    linear-gradient(35deg, transparent 38%, rgba(255, 225, 163, 0.5) 39%, transparent 58%);
  pointer-events: none;
}

.hero-mark {
  position: relative;
  z-index: 1;
  color: #9a6a00;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 700;
}

.hero-title {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  color: #1f1f1f;
  font-size: 52rpx;
  line-height: 68rpx;
  font-weight: 900;
}

.hero-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 8rpx;
  color: #7a6650;
  font-size: 27rpx;
  line-height: 38rpx;
}

.profile-card {
  position: relative;
  min-height: 224rpx;
  padding: 38rpx 34rpx;
  border-radius: 36rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 26rpx;
  background:
    linear-gradient(115deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 251, 242, 0.95) 100%);
  border: 1rpx solid rgba(213, 196, 171, 0.52);
  box-shadow: 0 14rpx 34rpx rgba(120, 83, 22, 0.08);
  overflow: hidden;
}

.profile-scene {
  position: absolute;
  right: 0;
  top: 0;
  width: 330rpx;
  height: 196rpx;
  background:
    radial-gradient(circle at 68% 64%, rgba(44, 35, 24, 0.18) 0, rgba(44, 35, 24, 0.18) 34rpx, transparent 36rpx),
    radial-gradient(circle at 82% 40%, rgba(255, 184, 0, 0.2), transparent 54rpx),
    linear-gradient(135deg, rgba(255, 236, 198, 0.54), rgba(255, 255, 255, 0));
  opacity: 0.9;
}

.avatar-shell {
  width: 142rpx;
  height: 142rpx;
  padding: 8rpx;
  border-radius: 50%;
  border: 7rpx solid #ffffff;
  box-sizing: border-box;
  overflow: hidden;
  background: rgba(255, 255, 255, 0);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  flex: none;
  position: relative;
  z-index: 1;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #fff8e7 0%, #ffb800 100%);
  color: #7c5800;
  font-size: 34rpx;
  font-weight: 800;
}

.identity {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.profile-name {
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 800;
  color: #222222;
  white-space: nowrap;
}

.vip-badge {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #b98400;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 800;
}

.profile-id {
  margin-top: 4rpx;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 500;
  color: #666666;
  white-space: nowrap;
}

.edit-button {
  position: relative;
  z-index: 1;
  width: 74rpx;
  height: 74rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(213, 196, 171, 0.58);
  flex: none;
}

.edit-icon {
  color: #7c5800;
  font-size: 32rpx;
  line-height: 32rpx;
}

.credits-card {
  position: relative;
  min-height: 188rpx;
  padding: 36rpx 34rpx;
  border-radius: 34rpx;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(105deg, #fff3c8 0%, #fffdf8 58%, #ffe8a2 100%);
  border: 1rpx solid rgba(255, 184, 0, 0.28);
  box-shadow: 0 16rpx 38rpx rgba(176, 128, 43, 0.12);
}

.coin-visual {
  position: relative;
  z-index: 1;
  width: 112rpx;
  height: 112rpx;
  margin-right: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at 35% 30%, #fff8d4 0%, #ffc21c 45%, #d49500 100%);
  color: #ffffff;
  font-size: 58rpx;
  box-shadow: 0 16rpx 28rpx rgba(218, 151, 0, 0.24);
}

.glow {
  position: absolute;
  width: 256rpx;
  height: 256rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  filter: blur(38rpx);
}

.glow-top {
  top: -77rpx;
  right: -77rpx;
}

.glow-bottom {
  left: -77rpx;
  bottom: -77rpx;
}

.credits-copy {
  position: relative;
  z-index: 1;
}

.credits-card app-button,
.guest-balance-card app-button {
  position: relative;
  z-index: 1;
  flex: none;
}

.credits-label {
  font-size: 28rpx;
  line-height: 40rpx;
  letter-spacing: 0;
  font-weight: 500;
  color: #6b4c00;
  opacity: 0.9;
}

.credits-row {
  margin-top: 8rpx;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  color: #6b4c00;
}

.credits-value {
  font-size: 56rpx;
  line-height: 72rpx;
  font-weight: 700;
}

.credit-unit {
  color: #6b4c00;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 500;
}

.section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.about-section {
  margin-top: -16rpx;
}

.logout-section {
  padding: 2rpx 0 18rpx;
}

.logout-button {
  width: 100%;
  height: 100rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(186, 26, 26, 0.12);
  border-radius: 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.86);
  color: #ba1a1a;
  font-size: 31rpx;
  line-height: 46rpx;
  font-weight: 500;
  box-shadow: 0 10rpx 28rpx rgba(186, 26, 26, 0.05);
}

.section-title {
  padding: 0 16rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  letter-spacing: 0;
  font-weight: 500;
  color: #222222;
  font-weight: 900;
}

.menu-card {
  overflow: hidden;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(213, 196, 171, 0.42);
  box-shadow: 0 12rpx 30rpx rgba(120, 83, 22, 0.07);
}

.menu-row {
  min-height: 112rpx;
  padding: 26rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bordered {
  border-bottom: 1rpx solid rgba(238, 238, 238, 0.5);
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex-wrap: wrap;
}

.action-icon-shell,
.about-icon-shell {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
}

.action-icon-shell {
  background: rgba(235, 225, 212, 0.3);
}

.about-icon-shell {
  background: #eeeeee;
}

.feedback-shell {
  background: rgba(255, 184, 0, 0.12);
}

.orders-icon {
  width: 35rpx;
  height: 38rpx;
  color: #7c5800;
  font-size: 28rpx;
  line-height: 38rpx;
  text-align: center;
}

.works-icon {
  width: 35rpx;
  height: 35rpx;
  color: #7c5800;
  font-size: 34rpx;
  line-height: 35rpx;
  text-align: center;
}

.about-icon {
  width: 38rpx;
  height: 38rpx;
  color: #666666;
  font-size: 28rpx;
  line-height: 38rpx;
  text-align: center;
  font-weight: 800;
}

.privacy-icon {
  width: 31rpx;
  height: 38rpx;
  color: #666666;
  font-size: 28rpx;
  line-height: 38rpx;
  text-align: center;
  font-weight: 800;
}

.feedback-icon {
  width: 38rpx;
  height: 38rpx;
  color: #7c5800;
  font-size: 28rpx;
  line-height: 38rpx;
  text-align: center;
  font-weight: 800;
}

.menu-text {
  font-size: 32rpx;
  line-height: 48rpx;
  font-weight: 500;
  color: #222222;
}

.chevron {
  width: 24rpx;
  height: 32rpx;
  flex: none;
  color: #d1c0a8;
  font-size: 42rpx;
  line-height: 32rpx;
  text-align: right;
}

.guest-main {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding-top: 16rpx;
}

.guest-profile-row {
  display: flex;
  align-items: center;
  gap: 31rpx;
}

.guest-avatar-image {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 144rpx;
  height: 144rpx;
  border: 8rpx solid #ffffff;
  border-radius: 50%;
  box-sizing: border-box;
  background: linear-gradient(145deg, #fff8e7 0%, #ffcf4a 100%);
  box-shadow: 0 8rpx 48rpx rgba(255, 184, 0, 0.1);
}

.guest-avatar-icon {
  color: #8a6200;
  font-size: 48rpx;
  line-height: 48rpx;
}

.guest-copy-wrap {
  flex: 1;
  min-width: 0;
}

.guest-title {
  color: #222222;
  font-size: 46rpx;
  line-height: 64rpx;
  font-weight: 500;
}

.guest-copy {
  margin-top: 4rpx;
  color: #666666;
  font-size: 27rpx;
  line-height: 38rpx;
}

.guest-chevron {
  color: #666666;
  font-size: 56rpx;
  line-height: 56rpx;
}

.guest-balance-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 164rpx;
  padding: 42rpx;
  border: 1rpx solid rgba(255, 184, 0, 0.2);
  border-radius: 30rpx;
  box-sizing: border-box;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(120, 83, 22, 0.07);
}

.guest-balance-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.guest-balance-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f3f3f3;
  color: #888888;
  font-size: 34rpx;
}

.guest-balance-title {
  color: #222222;
  font-size: 27rpx;
  line-height: 38rpx;
  font-weight: 500;
}

.guest-balance-desc {
  color: #666666;
  font-size: 27rpx;
  line-height: 38rpx;
}

.guest-menu-card {
  overflow: hidden;
  border: 1rpx solid rgba(213, 196, 171, 0.42);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 30rpx rgba(120, 83, 22, 0.07);
}

.guest-menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 108rpx;
  padding: 28rpx 34rpx;
  border-bottom: 1rpx solid rgba(238, 238, 238, 0.8);
  box-sizing: border-box;
}

.guest-menu-row.last {
  border-bottom: 0;
}

.guest-menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  color: #222222;
  font-size: 31rpx;
  line-height: 46rpx;
}

.guest-menu-icon {
  width: 36rpx;
  color: #666666;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
}
