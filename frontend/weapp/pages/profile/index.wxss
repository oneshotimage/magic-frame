.profile-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.profile-hero {
  padding: 36rpx;
  border-radius: 52rpx;
  background:
    radial-gradient(circle at 12% 0%, rgba(255, 255, 255, 0.8), transparent 34%),
    linear-gradient(135deg, #ffe7a7 0%, #ffbd47 52%, #ff875c 100%);
  box-shadow: 0 20rpx 54rpx rgba(255, 150, 61, 0.22);
}

.hero-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-shell {
  width: 128rpx;
  height: 128rpx;
  padding: 8rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.74);
  box-sizing: border-box;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #fff5e8;
}

.profile-main {
  min-width: 0;
  flex: 1;
}

.profile-name {
  color: #211b10;
  font-size: 42rpx;
  line-height: 52rpx;
  font-weight: 900;
}

.profile-id {
  margin-top: 10rpx;
  color: rgba(34, 34, 34, 0.62);
  font-size: 24rpx;
  font-weight: 700;
}

.edit-chip {
  min-width: 104rpx;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #4d3500;
  font-size: 24rpx;
  font-weight: 800;
}

.credits-card {
  margin-top: 32rpx;
  padding: 30rpx;
  border-radius: 36rpx;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #211b10;
}

.credits-label,
.credits-side {
  color: rgba(34, 34, 34, 0.58);
  font-size: 24rpx;
  line-height: 36rpx;
}

.credits-value {
  margin-top: 8rpx;
  font-size: 58rpx;
  line-height: 64rpx;
  font-weight: 900;
}

.credits-side {
  padding-top: 8rpx;
  text-align: right;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18rpx;
}

.quick-item {
  min-height: 148rpx;
  padding: 20rpx 8rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  background: #ffffff;
  border: 1rpx solid rgba(213, 196, 171, 0.62);
  color: #222222;
  font-size: 24rpx;
  font-weight: 800;
}

.quick-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff0c2;
  color: #7c5800;
  font-size: 24rpx;
  font-weight: 900;
}

.menu-section {
  overflow: hidden;
  border-radius: 36rpx;
  background: #ffffff;
  border: 1rpx solid rgba(213, 196, 171, 0.62);
}

.section-title {
  padding: 28rpx 32rpx 10rpx;
  color: #8a6a2c;
  font-size: 24rpx;
  font-weight: 900;
}

.menu-item {
  padding: 34rpx 32rpx;
  border-bottom: 1rpx solid #f1ece5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
  font-weight: 700;
}

.menu-item::after {
  content: "›";
  color: #b9aa91;
  font-size: 34rpx;
}

.menu-item:last-child {
  border-bottom: 0;
}

.account-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.compact-btn {
  height: 96rpx;
  font-size: 30rpx;
}

.guest-hero {
  position: relative;
  min-height: 720rpx;
  margin-top: 72rpx;
  padding: 52rpx 38rpx;
  border-radius: 56rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  background:
    radial-gradient(circle at 20% 16%, rgba(255, 184, 0, 0.26), transparent 32%),
    radial-gradient(circle at 84% 80%, rgba(255, 125, 69, 0.24), transparent 30%),
    #ffffff;
  border: 1rpx solid rgba(213, 196, 171, 0.62);
}

.guest-orbit {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 184, 0, 0.16);
}

.guest-orbit.one {
  width: 220rpx;
  height: 220rpx;
  left: -70rpx;
  top: 90rpx;
}

.guest-orbit.two {
  width: 300rpx;
  height: 300rpx;
  right: -120rpx;
  bottom: 40rpx;
}

.guest-avatar {
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffb800;
  color: #222222;
  font-size: 38rpx;
  font-weight: 900;
}

.guest-title {
  margin-top: 34rpx;
  font-size: 48rpx;
  line-height: 60rpx;
  font-weight: 900;
}

.guest-copy {
  max-width: 520rpx;
  margin-top: 18rpx;
  color: #666666;
  font-size: 28rpx;
  line-height: 44rpx;
}

.login-cta {
  margin-top: 46rpx;
}
