.profile-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 160rpx) 38rpx 184rpx;
  box-sizing: border-box;
  background: #f9f9f9;
  color: #222222;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  height: 92rpx;
  padding: 0 38rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(249, 249, 249, 0.8);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.bar-button {
  width: 62rpx;
  height: 62rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
}

.bar-button::after,
.edit-button::after,
.recharge-button::after,
.login-cta::after {
  border: 0;
}

.back-icon {
  color: #7c5800;
  font-size: 50rpx;
  line-height: 50rpx;
  font-weight: 500;
}

.more-icon {
  color: #7c5800;
  font-size: 28rpx;
  line-height: 28rpx;
  font-weight: 800;
}

.bar-title {
  font-size: 38rpx;
  line-height: 54rpx;
  font-weight: 500;
  color: #1a1c1c;
}

.main {
  display: flex;
  flex-direction: column;
  gap: 46rpx;
  padding-top: 30rpx;
}

.profile-card {
  min-height: 244rpx;
  padding: 46rpx;
  border-radius: 46rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 31rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 19rpx rgba(255, 184, 0, 0.1);
}

.avatar-shell {
  width: 154rpx;
  height: 154rpx;
  padding: 8rpx;
  border-radius: 50%;
  border: 8rpx solid #ffffff;
  box-sizing: border-box;
  overflow: hidden;
  background: rgba(255, 255, 255, 0);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  flex: none;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #fff8e7 0%, #ffb800 100%);
  color: #7c5800;
  font-size: 34rpx;
  font-weight: 800;
}

.identity {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 38rpx;
  line-height: 54rpx;
  font-weight: 500;
  color: #222222;
  white-space: nowrap;
}

.profile-id {
  margin-top: 2rpx;
  font-size: 23rpx;
  line-height: 31rpx;
  font-weight: 500;
  color: #666666;
  white-space: nowrap;
}

.edit-button {
  width: 77rpx;
  height: 77rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f3f3;
  flex: none;
}

.edit-icon {
  color: #7c5800;
  font-size: 34rpx;
  line-height: 34rpx;
}

.credits-card {
  position: relative;
  min-height: 208rpx;
  padding: 46rpx;
  border-radius: 46rpx;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(163deg, #ffb800 0%, #ffb599 100%);
  box-shadow: 0 8rpx 38rpx rgba(255, 184, 0, 0.1);
}

.glow {
  position: absolute;
  width: 246rpx;
  height: 246rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  filter: blur(38rpx);
}

.glow-top {
  top: -77rpx;
  right: -77rpx;
}

.glow-bottom {
  left: -77rpx;
  bottom: -77rpx;
}

.credits-copy,
.recharge-button {
  position: relative;
  z-index: 1;
}

.credits-card app-button,
.guest-balance-card app-button {
  position: relative;
  z-index: 1;
  flex: none;
}

.credits-label {
  font-size: 27rpx;
  line-height: 38rpx;
  letter-spacing: 0;
  font-weight: 500;
  color: #6b4c00;
  opacity: 0.9;
}

.credits-row {
  margin-top: 8rpx;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  color: #6b4c00;
}

.credits-value {
  font-size: 54rpx;
  line-height: 69rpx;
  font-weight: 700;
}

.credit-icon {
  width: 25rpx;
  height: 25rpx;
  color: #6b4c00;
  font-size: 24rpx;
  line-height: 25rpx;
}

.recharge-button {
  min-width: 173rpx;
  height: 69rpx;
  padding: 0 46rpx;
  margin: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  color: #222222;
  font-size: 27rpx;
  line-height: 38rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 2rpx rgba(0, 0, 0, 0.05);
}

.section {
  display: flex;
  flex-direction: column;
  gap: 23rpx;
}

.about-section {
  margin-top: -15rpx;
}

.section-title {
  padding: 0 15rpx;
  font-size: 27rpx;
  line-height: 38rpx;
  letter-spacing: 0;
  font-weight: 500;
  color: #666666;
}

.menu-card {
  overflow: hidden;
  border-radius: 46rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 38rpx rgba(255, 184, 0, 0.1);
}

.menu-row {
  min-height: 108rpx;
  padding: 31rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bordered {
  border-bottom: 1rpx solid rgba(238, 238, 238, 0.5);
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 23rpx;
}

.action-icon-shell,
.about-icon-shell {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
}

.action-icon-shell {
  background: rgba(235, 225, 212, 0.3);
}

.about-icon-shell {
  background: #eeeeee;
}

.orders-icon {
  width: 35rpx;
  height: 38rpx;
  color: #7c5800;
  font-size: 28rpx;
  line-height: 38rpx;
  text-align: center;
}

.works-icon {
  width: 35rpx;
  height: 35rpx;
  color: #7c5800;
  font-size: 34rpx;
  line-height: 35rpx;
  text-align: center;
}

.about-icon {
  width: 38rpx;
  height: 38rpx;
  color: #666666;
  font-size: 28rpx;
  line-height: 38rpx;
  text-align: center;
  font-weight: 800;
}

.privacy-icon {
  width: 31rpx;
  height: 38rpx;
  color: #666666;
  font-size: 28rpx;
  line-height: 38rpx;
  text-align: center;
  font-weight: 800;
}

.menu-text {
  font-size: 31rpx;
  line-height: 46rpx;
  font-weight: 500;
  color: #222222;
}

.chevron {
  width: 24rpx;
  height: 32rpx;
  flex: none;
  color: #d1c0a8;
  font-size: 42rpx;
  line-height: 30rpx;
  text-align: right;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  min-height: 119rpx;
  padding: 23rpx 100rpx calc(env(safe-area-inset-bottom) + 8rpx) 94rpx;
  border-radius: 23rpx 23rpx 0 0;
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  background: #ffffff;
  box-shadow: 0 -8rpx 19rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  width: 123rpx;
  min-height: 73rpx;
  padding: 8rpx 0;
  border-radius: 23rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: none;
}

.tab-item.active {
  transform: scale(0.9);
  background: rgba(235, 225, 212, 0.1);
}

.tab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #645e54;
  font-weight: 700;
}

.home-tab {
  width: 31rpx;
  height: 42rpx;
}

.works-tab {
  width: 38rpx;
  height: 46rpx;
}

.mine-tab {
  width: 31rpx;
  height: 38rpx;
  color: #7c5800;
}

.tab-label {
  margin-top: 0;
  font-size: 19rpx;
  line-height: 27rpx;
  font-weight: 500;
  color: #645e54;
}

.active-label {
  color: #7c5800;
}

.guest-main {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
  padding-top: 32rpx;
}

.guest-profile-row {
  display: flex;
  align-items: center;
  gap: 31rpx;
}

.guest-avatar-image {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 144rpx;
  height: 144rpx;
  border: 8rpx solid #ffffff;
  border-radius: 50%;
  box-sizing: border-box;
  background: #e2e2e2;
  box-shadow: 0 8rpx 48rpx rgba(255, 184, 0, 0.1);
}

.guest-avatar-icon {
  color: #666666;
  font-size: 48rpx;
  line-height: 48rpx;
}

.guest-copy-wrap {
  flex: 1;
  min-width: 0;
}

.guest-title {
  color: #222222;
  font-size: 46rpx;
  line-height: 64rpx;
  font-weight: 500;
}

.guest-copy {
  margin-top: 4rpx;
  color: #666666;
  font-size: 27rpx;
  line-height: 38rpx;
}

.guest-chevron {
  color: #666666;
  font-size: 56rpx;
  line-height: 56rpx;
}

.guest-balance-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 164rpx;
  padding: 42rpx;
  border: 2rpx solid #e2e2e2;
  border-radius: 24rpx;
  box-sizing: border-box;
  background: #ffffff;
  box-shadow: 0 8rpx 48rpx rgba(255, 184, 0, 0.1);
}

.guest-balance-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.guest-balance-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f3f3f3;
  color: #888888;
  font-size: 34rpx;
}

.guest-balance-title {
  color: #222222;
  font-size: 27rpx;
  line-height: 38rpx;
  font-weight: 500;
}

.guest-balance-desc {
  color: #666666;
  font-size: 27rpx;
  line-height: 38rpx;
}

.guest-recharge {
  min-width: 124rpx;
  height: 72rpx;
  margin: 0;
  padding: 0 32rpx;
  border-radius: 999rpx;
  background: #f3f3f3;
  color: #666666;
  font-size: 27rpx;
  line-height: 38rpx;
}

.guest-recharge::after {
  border: 0;
}

.guest-menu-card {
  overflow: hidden;
  border: 2rpx solid #e2e2e2;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 48rpx rgba(255, 184, 0, 0.1);
}

.guest-menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 114rpx;
  padding: 32rpx 40rpx;
  border-bottom: 2rpx solid #f3f3f3;
  box-sizing: border-box;
}

.guest-menu-row.last {
  border-bottom: 0;
}

.guest-menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  color: #222222;
  font-size: 31rpx;
  line-height: 46rpx;
}

.guest-menu-icon {
  width: 36rpx;
  color: #666666;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
}
