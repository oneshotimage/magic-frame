.poster-shell {
  min-height: 100vh;
  background: #f8f8f8;
}

.poster-page {
  padding-top: calc(env(safe-area-inset-top) + 160rpx);
}

.poster-card {
  overflow: hidden;
  border-radius: 48rpx;
  background: #ffffff;
  border: 1rpx solid rgba(213, 196, 171, 0.62);
}

.poster-image,
.poster-empty {
  width: 100%;
  height: 820rpx;
  background: #fff5e8;
}

.poster-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666666;
}

.poster-caption {
  padding: 28rpx 32rpx;
  font-size: 34rpx;
  font-weight: 800;
}
