.style-option {
  overflow: hidden;
  border-radius: 48rpx;
  border: 4rpx solid transparent;
  background: #ffffff;
  box-shadow: 0 10rpx 36rpx rgba(255, 184, 0, 0.08);
}

.style-option.active {
  border-color: #ffb800;
}

.style-option image {
  width: 100%;
  height: 300rpx;
  display: block;
}

.option-info {
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.option-info text {
  display: block;
  margin-top: 6rpx;
  color: #666;
  font-size: 24rpx;
  font-weight: 400;
}
