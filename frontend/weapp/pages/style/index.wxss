.style-option {
  overflow: hidden;
  border-radius: 48rpx;
  border: 4rpx solid transparent;
  background: #ffffff;
  box-shadow: 0 10rpx 36rpx rgba(255, 184, 0, 0.08);
}

.style-option.active {
  border-color: #ffb800;
}

.style-cover {
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.style-cover.pixar {
  background: linear-gradient(145deg, #b9e9ff 0%, #ffb800 100%);
}

.style-cover.realistic {
  background: linear-gradient(145deg, #f9e3c9 0%, #c8895f 56%, #3d261d 100%);
}

.style-cover.handdrawn {
  background: linear-gradient(145deg, #fde7ef 0%, #b8d8c5 50%, #fff0c2 100%);
}

.style-cover.comic {
  background: linear-gradient(145deg, #ffe15a 0%, #ff7d45 50%, #6b4cff 100%);
}

.style-symbol {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.72);
  color: #7c5800;
  font-size: 38rpx;
  font-weight: 800;
}

.option-info {
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.option-info text {
  display: block;
  margin-top: 6rpx;
  color: #666;
  font-size: 24rpx;
  font-weight: 400;
}
