<view class="page safe-tab stack">
  <view class="result-head">
    <view>
      <view class="title">作品集</view>
      <view class="subtitle">{{images.length}} 张已生成作品</view>
    </view>
    <view wx:if="{{loading}}" class="status-pill">加载中</view>
  </view>

  <view wx:if="{{images.length}}" class="result-grid">
    <view wx:for="{{images}}" wx:key="url" class="result-card" bindtap="preview" data-url="{{item.url}}">
      <image class="result-image" mode="aspectFill" src="{{item.url}}" />
      <view class="result-name">{{item.style || item.styleId || '写真作品'}}</view>
    </view>
  </view>

  <view wx:else class="card empty">
    <view class="title">还没有作品</view>
    <view class="subtitle">选择照片和风格后即可生成第一组 AI 写真。</view>
    <button class="primary-btn" bindtap="create">去生成</button>
  </view>
</view>
