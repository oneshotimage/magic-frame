.faq-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f2eb 0%, #f5e2cc 100%);
  color: #29231d;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 112rpx;
  padding: 44rpx 24rpx 0;
  box-sizing: border-box;
}

.bar-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  border-radius: 32rpx;
  background: transparent;
  color: #221b15;
}

.bar-button::after {
  border: 0;
}

.back-icon {
  font-size: 52rpx;
  line-height: 1;
}

.more-icon {
  font-size: 30rpx;
  letter-spacing: 0;
}

.bar-title {
  font-size: 30rpx;
  font-weight: 600;
}

.main {
  padding: 46rpx 32rpx 72rpx;
}

.help-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: #f7bf3b;
  color: #fff;
  font-size: 76rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 34rpx rgba(186, 117, 16, 0.2);
}

.title {
  margin-top: 36rpx;
  text-align: center;
  font-size: 40rpx;
  line-height: 52rpx;
  font-weight: 700;
}

.subtitle {
  width: 586rpx;
  max-width: 100%;
  margin: 18rpx auto 0;
  color: rgba(55, 45, 35, 0.68);
  text-align: center;
  font-size: 26rpx;
  line-height: 40rpx;
}

.search-box {
  display: flex;
  align-items: center;
  height: 92rpx;
  margin-top: 46rpx;
  padding: 0 30rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 12rpx 32rpx rgba(133, 91, 43, 0.1);
  box-sizing: border-box;
}

.search-icon {
  margin-right: 16rpx;
  color: rgba(55, 45, 35, 0.46);
  font-size: 34rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  color: #2d261e;
  font-size: 28rpx;
}

.search-placeholder {
  color: rgba(61, 51, 39, 0.44);
}

.faq-list {
  margin-top: 30rpx;
}

.faq-item {
  margin-bottom: 18rpx;
  padding: 30rpx 30rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 10rpx 28rpx rgba(133, 91, 43, 0.08);
}

.question-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.question {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 600;
}

.chevron {
  margin-left: 18rpx;
  color: rgba(44, 36, 28, 0.52);
  font-size: 34rpx;
  transition: transform 0.18s ease;
}

.chevron.open {
  transform: rotate(180deg);
}

.answer {
  margin-top: 18rpx;
  color: rgba(58, 48, 38, 0.68);
  font-size: 26rpx;
  line-height: 40rpx;
}

.contact-card {
  margin-top: 42rpx;
  padding: 40rpx 34rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.76);
  text-align: center;
}

.contact-title {
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 700;
}

.contact-text {
  margin-top: 12rpx;
  color: rgba(59, 48, 37, 0.64);
  font-size: 26rpx;
  line-height: 38rpx;
}

.contact-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 420rpx;
  max-width: 100%;
  height: 88rpx;
  margin: 30rpx auto 0;
  border: 0;
  border-radius: 44rpx;
  background: linear-gradient(180deg, #ffd86b 0%, #f3b22a 100%);
  color: #39250d;
  font-size: 30rpx;
  font-weight: 700;
}

.contact-btn::after {
  border: 0;
}
