.faq-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.faq-card {
  padding: 32rpx;
  border-radius: 36rpx;
  background: #ffffff;
  border: 1rpx solid rgba(213, 196, 171, 0.62);
}

.question {
  font-size: 30rpx;
  font-weight: 800;
  color: #222222;
}

.answer {
  margin-top: 16rpx;
  color: #666666;
  font-size: 26rpx;
  line-height: 42rpx;
}
