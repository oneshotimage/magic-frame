<view class="faq-page">
  <nav-bar title="常见问题" fixed="{{false}}" bind:back="goBack" />

  <view class="main">
    <view class="help-icon">?</view>
    <view class="title">如何我们可以帮到您？</view>
    <view class="subtitle">在这里寻找关于AI影像生成、支付和账号等常见问题的解答。</view>

    <view class="search-box">
      <text class="search-icon">⌕</text>
      <input class="search-input" value="{{keyword}}" placeholder="搜索问题..." placeholder-class="search-placeholder" bindinput="onSearch" />
    </view>

    <view class="faq-list">
      <view wx:for="{{filteredFaqs}}" wx:key="q" class="faq-item" bindtap="toggleFaq" data-index="{{index}}">
        <view class="question-row">
          <view class="question">{{item.q}}</view>
          <text class="chevron {{activeIndex == index ? 'open' : ''}}">⌄</text>
        </view>
        <view wx:if="{{activeIndex == index}}" class="answer">{{item.a}}</view>
      </view>
    </view>

    <view class="contact-card">
      <view class="contact-title">还有其他问题？</view>
      <view class="contact-text">我们的客服团队随时准备为您提供帮助</view>
      <app-button text="联系在线客服" icon="" openType="contact" />
    </view>
  </view>
</view>
