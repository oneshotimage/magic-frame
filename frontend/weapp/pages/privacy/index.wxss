.privacy-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f1e9 0%, #f2ddc5 100%);
  color: #2c251e;
}

.content {
  height: calc(100vh - 112rpx);
  padding: 34rpx 28rpx 0;
  box-sizing: border-box;
}

.header {
  margin-bottom: 28rpx;
  text-align: center;
}

.doc-title {
  font-size: 46rpx;
  line-height: 58rpx;
  font-weight: 700;
}

.doc-date {
  margin-top: 12rpx;
  color: rgba(55, 45, 34, 0.52);
  font-size: 24rpx;
  line-height: 34rpx;
}

.policy-card {
  margin-bottom: 24rpx;
  padding: 34rpx 32rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 14rpx 34rpx rgba(128, 88, 43, 0.09);
  box-sizing: border-box;
}

.section-title {
  margin-bottom: 18rpx;
  color: #251f18;
  font-size: 32rpx;
  line-height: 42rpx;
  font-weight: 700;
}

.section-text {
  margin-top: 16rpx;
  color: rgba(48, 40, 32, 0.78);
  font-size: 27rpx;
  line-height: 46rpx;
}

.contact-text {
  margin: 26rpx 18rpx 0;
  color: rgba(55, 45, 34, 0.62);
  text-align: center;
  font-size: 24rpx;
  line-height: 38rpx;
}

.agree-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  margin: 28rpx 8rpx calc(38rpx + env(safe-area-inset-bottom));
  border: 0;
  border-radius: 46rpx;
  background: linear-gradient(180deg, #ffd86b 0%, #f3b22a 100%);
  color: #39250d;
  font-size: 30rpx;
  font-weight: 700;
}

.agree-btn::after {
  border: 0;
}
