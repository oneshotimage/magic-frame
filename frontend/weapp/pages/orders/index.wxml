<view class="page stack">
  <view>
    <view class="title">订单记录</view>
    <view class="subtitle">查看充值与支付状态</view>
  </view>

  <view wx:if="{{orders.length}}" class="order-list">
    <view wx:for="{{orders}}" wx:key="orderId" class="order-card">
      <view class="order-top">
        <view class="order-name">{{item.packageName || item.packageId}}</view>
        <view class="status-pill">{{item.status}}</view>
      </view>
      <view class="muted">订单号：{{item.orderId}}</view>
      <view class="order-price">¥{{item.amountFen / 100}}</view>
      <button wx:if="{{item.status === 'PENDING'}}" class="secondary-btn" bindtap="closeOrder" data-id="{{item.orderId}}">关闭订单</button>
    </view>
  </view>

  <view wx:else class="card stack">
    <view class="title">暂无订单</view>
    <view class="subtitle">购买生成次数后会出现在这里。</view>
    <button class="primary-btn" bindtap="purchase">去购买</button>
  </view>
</view>
