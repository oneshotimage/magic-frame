.home-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 146rpx) 26rpx 330rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 184, 0, 0.13) 0, rgba(255, 184, 0, 0) 330rpx),
    linear-gradient(180deg, #fffaf4 0%, #fffdf8 46%, #faf9f6 100%);
  color: #222222;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.main {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.home-hero {
  position: relative;
  height: 467rpx;
  overflow: hidden;
  border-radius: 34rpx;
  background: #2d261f;
  box-shadow: 0 18rpx 46rpx rgba(98, 64, 18, 0.12);
}

.home-hero-img {
  width: 100%;
  height: 100%;
  display: block;
  transform: scale(1.03);
  transform-origin: 58% 50%;
}

.hero-gradient {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg, rgba(0, 0, 0, 0.62) 0%, rgba(0, 0, 0, 0.28) 43%, rgba(0, 0, 0, 0.03) 100%),
    linear-gradient(180deg, rgba(0, 0, 0, 0.03) 0%, rgba(0, 0, 0, 0.18) 100%);
}

.hero-info {
  position: absolute;
  left: 44rpx;
  right: 44rpx;
  top: 116rpx;
  z-index: 2;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.hero-copy {
  min-width: 0;
}

.hero-title {
  color: #ffffff;
  font-size: 53rpx;
  line-height: 1.15;
  font-weight: 800;
  letter-spacing: 0;
  text-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.24);
}

.hero-subtitle {
  margin-top: 27rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
  line-height: 1.48;
  font-weight: 500;
  letter-spacing: 0;
  text-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.28);
}

.credit-badge {
  min-height: 58rpx;
  margin-top: 31rpx;
  padding: 10rpx 28rpx 10rpx 15rpx;
  border: 1rpx solid rgba(255, 232, 186, 0.88);
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: rgba(255, 253, 246, 0.94);
  box-shadow: 0 10rpx 24rpx rgba(48, 28, 0, 0.16);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.credit-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #ffb800;
  border-radius: 50%;
  color: #ffffff;
  font-size: 23rpx;
  line-height: 44rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #ffd35c 0%, #ff9f00 100%);
  box-shadow: inset 0 2rpx 4rpx rgba(255, 255, 255, 0.48);
}

.credit-label {
  color: #222222;
  font-size: 26rpx;
  line-height: 38rpx;
  font-weight: 600;
  white-space: nowrap;
}

.credit-value {
  color: #ff9f00;
  font-size: 32rpx;
  line-height: 38rpx;
  font-weight: 800;
  white-space: nowrap;
}

.workflow-card {
  min-height: 108rpx;
  padding: 19rpx 29rpx;
  border: 1rpx solid rgba(255, 184, 0, 0.22);
  border-radius: 22rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 11rpx;
  background: rgba(255, 250, 239, 0.82);
  box-shadow: 0 10rpx 30rpx rgba(122, 80, 7, 0.06);
}

.workflow-step {
  min-width: 0;
  flex: 1 1 0;
  display: flex;
  align-items: center;
  gap: 13rpx;
}

.workflow-icon {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  flex: none;
  border: 1rpx solid rgba(160, 117, 35, 0.28);
  border-radius: 50%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.76);
  color: #1e1a14;
  font-size: 25rpx;
  line-height: 56rpx;
  font-weight: 700;
}

.upload-icon::before {
  content: "";
  width: 26rpx;
  height: 20rpx;
  border: 3rpx solid #1f1b13;
  border-top: 0;
  border-radius: 0 0 8rpx 8rpx;
  box-sizing: border-box;
}

.upload-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 13rpx;
  width: 15rpx;
  height: 15rpx;
  border-left: 3rpx solid #1f1b13;
  border-top: 3rpx solid #1f1b13;
  transform: translateX(-50%) rotate(45deg);
}

.camera-icon::before {
  content: "";
  width: 28rpx;
  height: 22rpx;
  border: 3rpx solid #1f1b13;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.camera-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 9rpx;
  height: 9rpx;
  border: 3rpx solid #1f1b13;
  border-radius: 50%;
  transform: translate(-50%, -42%);
}

.workflow-copy {
  min-width: 0;
}

.workflow-title {
  color: #222222;
  font-size: 22rpx;
  line-height: 31rpx;
  font-weight: 700;
  white-space: nowrap;
}

.workflow-desc {
  margin-top: 3rpx;
  color: #8a765a;
  font-size: 19rpx;
  line-height: 26rpx;
  font-weight: 500;
  white-space: nowrap;
}

.workflow-line {
  width: 47rpx;
  height: 1rpx;
  flex: none;
  border-top: 3rpx dotted rgba(122, 80, 7, 0.34);
}

.style-section {
  margin-top: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  color: #222222;
  font-size: 38rpx;
  line-height: 55rpx;
  font-weight: 800;
}

.section-title text {
  color: #ffb000;
  font-size: 27rpx;
  vertical-align: 5rpx;
}

.view-all {
  color: #8a6322;
  font-size: 24rpx;
  line-height: 35rpx;
  font-weight: 600;
}

.style-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx 22rpx;
}

.style-card {
  position: relative;
  height: 246rpx;
  padding: 0;
  border: 0;
  border-radius: 19rpx;
  box-sizing: border-box;
  overflow: hidden;
  background: #d9cbb5;
  box-shadow: 0 10rpx 28rpx rgba(36, 25, 11, 0.09);
}

.style-card.active {
  box-shadow: 0 0 0 4rpx #ffb800, 0 10rpx 28rpx rgba(36, 25, 11, 0.09);
}

.style-image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 19rpx;
}

.style-mask {
  position: absolute;
  inset: 0;
  padding: 0 74rpx 18rpx 18rpx;
  border-radius: 19rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 32%, rgba(0, 0, 0, 0.2) 62%, rgba(0, 0, 0, 0.74) 100%);
}

.style-name {
  color: #ffffff;
  font-size: 30rpx;
  line-height: 43rpx;
  font-weight: 800;
  text-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.38);
}

.style-desc {
  margin-top: 2rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 22rpx;
  line-height: 32rpx;
  font-weight: 600;
}

.hot {
  position: absolute;
  top: 16rpx;
  right: 17rpx;
  z-index: 2;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffc845 0%, #ffa800 100%);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 800;
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
  box-shadow: 0 6rpx 16rpx rgba(255, 168, 0, 0.25);
}

.style-arrow {
  position: absolute;
  right: 18rpx;
  bottom: 21rpx;
  z-index: 3;
  width: 51rpx;
  height: 51rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.84);
  color: #1f1b13;
  font-size: 45rpx;
  line-height: 45rpx;
  font-weight: 600;
  box-shadow: 0 5rpx 18rpx rgba(0, 0, 0, 0.2);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.cta-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(env(safe-area-inset-bottom) + 151rpx);
  z-index: 34;
  padding: 78rpx 38rpx 27rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(250, 249, 246, 0) 0%, rgba(250, 249, 246, 0.9) 43%, #faf9f6 100%);
}
