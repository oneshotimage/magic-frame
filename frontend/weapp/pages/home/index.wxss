.home-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 154rpx) 38rpx 306rpx;
  box-sizing: border-box;
  background: #f9f9f9;
  color: #222222;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.main {
  display: flex;
  flex-direction: column;
  gap: 46rpx;
}

.home-hero {
  overflow: hidden;
  border-radius: 46rpx;
  background: #ffffff;
  box-shadow: 0 15rpx 46rpx rgba(255, 184, 0, 0.05);
}

.hero-image-wrap {
  position: relative;
  height: 369rpx;
  overflow: hidden;
}

.home-hero-img {
  width: 100%;
  height: 100%;
  display: block;
}

.hero-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.5) 100%);
}

.hero-info {
  position: relative;
  z-index: 1;
  min-height: 215rpx;
  margin-top: -92rpx;
  padding: 38rpx;
  border-radius: 46rpx 46rpx 0 0;
  box-sizing: border-box;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 23rpx;
  background: rgba(255, 255, 255, 0.85);
  -webkit-backdrop-filter: blur(15rpx);
  backdrop-filter: blur(15rpx);
}

.hero-copy {
  min-width: 0;
}

.hero-title {
  color: #222222;
  font-size: 54rpx;
  line-height: 69rpx;
  font-weight: 500;
}

.hero-subtitle {
  margin-top: 15rpx;
  color: #666666;
  font-size: 27rpx;
  line-height: 38rpx;
  font-weight: 500;
  letter-spacing: 0.2rpx;
}

.credit-badge {
  min-width: 181rpx;
  min-height: 73rpx;
  margin-bottom: 8rpx;
  padding: 17rpx 25rpx;
  border: 2rpx solid rgba(255, 184, 0, 0.3);
  border-radius: 23rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 184, 0, 0.1);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  -webkit-backdrop-filter: blur(4rpx);
  backdrop-filter: blur(4rpx);
  flex: none;
}

.credit-icon {
  width: 29rpx;
  height: 29rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ffb800;
  border-radius: 50%;
  color: #ffb800;
  font-size: 18rpx;
  line-height: 29rpx;
  box-sizing: border-box;
}

.credit-text {
  color: #222222;
  font-size: 23rpx;
  line-height: 31rpx;
  font-weight: 500;
  white-space: nowrap;
}

.style-section {
  display: flex;
  flex-direction: column;
  gap: 31rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  color: #222222;
  font-size: 46rpx;
  line-height: 62rpx;
  font-weight: 500;
}

.view-all {
  color: #7c5800;
  font-size: 23rpx;
  line-height: 31rpx;
  font-weight: 500;
}

.style-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 23rpx;
}

.style-card {
  position: relative;
  height: 433rpx;
  padding: 4rpx;
  border: 4rpx solid transparent;
  border-radius: 46rpx;
  box-sizing: border-box;
  overflow: hidden;
  background: transparent;
  box-shadow: 0 8rpx 31rpx rgba(0, 0, 0, 0.04);
}

.style-card.active {
  border-color: #ffb800;
}

.style-image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 40rpx;
}

.style-mask {
  position: absolute;
  inset: 4rpx;
  padding: 31rpx;
  border-radius: 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.1) 50%, rgba(0, 0, 0, 0.7) 100%);
}

.style-name {
  color: #ffffff;
  font-size: 38rpx;
  line-height: 54rpx;
  font-weight: 600;
}

.style-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 23rpx;
  line-height: 31rpx;
  font-weight: 500;
}

.hot {
  position: absolute;
  top: 23rpx;
  right: 23rpx;
  z-index: 2;
  padding: 8rpx 15rpx;
  border-radius: 999rpx;
  background: #ebe1d4;
  color: #1f1b13;
  font-size: 19rpx;
  line-height: 29rpx;
  font-weight: 600;
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.cta-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(env(safe-area-inset-bottom) + 154rpx);
  z-index: 34;
  padding: 92rpx 38rpx 31rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(249, 249, 249, 0) 0%, rgba(249, 249, 249, 0.9) 50%, #f9f9f9 100%);
}
