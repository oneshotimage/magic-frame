<view class="home-page">
  <nav-bar title="AI影像写真馆" bind:back="goBack" />

  <view class="main">
    <view class="home-hero">
      <view class="hero-image-wrap">
        <image class="home-hero-img" mode="aspectFill" src="{{heroImage}}" />
        <view class="hero-gradient"></view>
      </view>
      <view class="hero-info">
        <view class="hero-copy">
          <view class="hero-title">
            <view>AI艺术写真</view>
            <view>一键生成</view>
          </view>
          <view class="hero-subtitle">
            <view>上传一张照片，遇见不同风格的</view>
            <view>自己</view>
          </view>
        </view>
        <view class="credit-badge">
          <view class="credit-icon">✦</view>
          <view class="credit-text">
            <view>剩余次数:</view>
            <view>{{creditText}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="style-section">
      <view class="section-head">
        <view class="section-title">选择风格</view>
        <view class="view-all" bindtap="goStyle">查看全部</view>
      </view>
      <view class="style-grid">
        <block wx:for="{{styles}}" wx:key="id">
          <view class="style-card {{selectedMap[item.id] ? 'active' : ''}}" data-id="{{item.id}}" bindtap="toggleStyle">
            <image class="style-image" mode="aspectFill" src="{{item.image}}" />
            <view wx:if="{{item.badge}}" class="hot">{{item.badge}}</view>
            <view class="style-mask">
              <view class="style-name">{{item.short}}</view>
              <view class="style-desc">{{item.desc}}</view>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="cta-wrap">
    <app-button text="立即制作" icon="✦" variant="home-cta" bind:press="goUpload" />
  </view>

  <app-tabbar active="home" />
</view>
