<view class="home-page">
  <nav-bar title="妙影工坊" variant="home" bind:back="goBack" />

  <view class="main">
    <view class="home-hero">
      <image class="home-hero-img" mode="aspectFill" src="{{heroImage}}" />
      <view class="hero-gradient"></view>
      <view class="hero-info">
        <view class="hero-copy">
          <view class="hero-title">
            <view>AI艺术写真</view>
            <view>一键生成</view>
          </view>
          <view class="hero-subtitle">
            <view>上传一张照片，遇见不同风格的</view>
            <view>自己</view>
          </view>
        </view>
        <view class="credit-badge">
          <view class="credit-icon">✦</view>
          <text class="credit-label">剩余次数</text>
          <text class="credit-value">{{creditText}}</text>
        </view>
      </view>
    </view>

    <view class="workflow-card">
      <view class="workflow-step">
        <view class="workflow-icon upload-icon"></view>
        <view class="workflow-copy">
          <view class="workflow-title">1. 上传照片</view>
          <view class="workflow-desc">真人正面更佳</view>
        </view>
      </view>
      <view class="workflow-line"></view>
      <view class="workflow-step">
        <view class="workflow-icon sparkle-icon">✦</view>
        <view class="workflow-copy">
          <view class="workflow-title">2. 选择风格</view>
          <view class="workflow-desc">多种风格可选</view>
        </view>
      </view>
      <view class="workflow-line"></view>
      <view class="workflow-step">
        <view class="workflow-icon camera-icon"></view>
        <view class="workflow-copy">
          <view class="workflow-title">3. AI生成</view>
          <view class="workflow-desc">专属写真出片</view>
        </view>
      </view>
    </view>

    <view class="style-section">
      <view class="section-head">
        <view class="section-title">选择风格 <text>✦</text></view>
        <view class="view-all" bindtap="goStyle">查看全部 ›</view>
      </view>
      <view class="style-grid">
        <block wx:for="{{styles}}" wx:key="id">
          <view class="style-card {{selectedMap[item.id] ? 'active' : ''}}" data-id="{{item.id}}" bindtap="toggleStyle">
            <image class="style-image" mode="aspectFill" src="{{item.image}}" />
            <view wx:if="{{item.badge}}" class="hot">{{item.badge}}</view>
            <view class="style-mask">
              <view class="style-name">{{item.short}}</view>
              <view class="style-desc">{{item.desc}}</view>
            </view>
            <view class="style-arrow">›</view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="cta-wrap">
    <app-button text="立即制作" icon="✦" variant="home-cta" bind:press="goUpload" />
  </view>

  <app-tabbar active="home" />
</view>
