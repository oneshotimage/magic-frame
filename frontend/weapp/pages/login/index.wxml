<view class="login-page">
  <view class="warm-bg"></view>
  <view class="glow glow-right"></view>
  <view class="glow glow-left"></view>

  <nav-bar title="" fixed="{{false}}" showMore="{{false}}" bind:back="goBack" />

  <view class="brand-panel">
    <view class="app-logo">
      <view class="logo-spark main">✦</view>
      <view class="logo-spark small-a">✦</view>
      <view class="logo-spark small-b">✦</view>
    </view>
    <view class="brand-title">AI影像写真馆</view>
    <view class="brand-subtitle">
      <view>登录后即可保存您的艺术写真，</view>
      <view>多端同步作品集。</view>
    </view>
  </view>

  <view class="login-actions">
    <app-button text="微信一键登录" icon="" loading="{{loading}}" disabled="{{loading}}" bind:press="login" />
    <button class="phone-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="skipProfile">手机号登录/注册</button>

    <view class="agreement-row" bindtap="toggleAgree">
      <view class="check {{agreed ? 'checked' : ''}}">{{agreed ? '✓' : ''}}</view>
      <view class="agreement-text">
        <text>我已阅读并同意 </text>
        <text class="link" catchtap="openAgreement">《用户协议》</text>
        <text> 与 </text>
        <text class="link" catchtap="openPrivacy">《隐私政策》</text>
      </view>
    </view>
  </view>
</view>
