.login-page {
  padding: 0;
  display: flex;
  flex-direction: column;
  background: #f8f8f8;
}

.login-visual {
  position: relative;
  min-height: 58vh;
  overflow: hidden;
  border-bottom-left-radius: 64rpx;
  border-bottom-right-radius: 64rpx;
  background: #fff5e8;
}

.login-image {
  width: 100%;
  height: 58vh;
}

.login-brand {
  position: absolute;
  top: 76rpx;
  left: 40rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #222222;
  font-size: 26rpx;
  font-weight: 800;
}

.login-copy {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  bottom: 42rpx;
  padding: 36rpx;
  border-radius: 44rpx;
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(18rpx);
}

.login-panel {
  padding: 36rpx 40rpx calc(env(safe-area-inset-bottom) + 48rpx);
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.profile-form {
  padding: 28rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(213, 196, 171, 0.62);
}

.avatar-picker {
  width: 112rpx;
  height: 112rpx;
  padding: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff5e8;
  color: #7c5800;
  font-size: 24rpx;
  font-weight: 800;
}

.avatar-img {
  width: 112rpx;
  height: 112rpx;
  border-radius: 999rpx;
}

.nickname-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  color: #222222;
  font-size: 30rpx;
}

.agreement-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 36rpx;
}

.check {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 2rpx solid #d8c8ac;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #222222;
  font-size: 22rpx;
  font-weight: 900;
}

.check.checked {
  border-color: #ffb800;
  background: #ffb800;
}

.link {
  color: #7c5800;
  font-weight: 800;
}
