.login-page {
  position: relative;
  min-height: 100vh;
  padding: 0 58rpx calc(env(safe-area-inset-bottom) + 48rpx);
  box-sizing: border-box;
  overflow: hidden;
  background:
    radial-gradient(circle at 90% 12%, rgba(255, 184, 0, 0.22) 0, rgba(255, 184, 0, 0) 300rpx),
    linear-gradient(180deg, #fffaf2 0%, #faf7ef 100%);
  color: #2a1b10;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.brand-lockup {
  position: relative;
  z-index: 1;
  padding-top: 66rpx;
}

.logo-mark {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ffc21c 0%, #ffa600 100%);
  color: #ffffff;
  font-size: 74rpx;
  line-height: 74rpx;
  font-weight: 900;
  box-shadow: 0 18rpx 38rpx rgba(255, 184, 0, 0.22);
}

.logo-mark text {
  position: absolute;
  right: 24rpx;
  bottom: 20rpx;
  font-size: 24rpx;
}

.brand-title {
  margin-top: 48rpx;
  color: #2a1b10;
  font-size: 72rpx;
  line-height: 90rpx;
  font-weight: 800;
}

.brand-en {
  color: #b47700;
  font-size: 42rpx;
  line-height: 58rpx;
  font-weight: 500;
}

.brand-copy {
  width: 430rpx;
  margin-top: 48rpx;
  color: #3c2b20;
  font-size: 32rpx;
  line-height: 50rpx;
  font-weight: 500;
}

.studio-preview {
  position: relative;
  height: 610rpx;
  margin-top: 10rpx;
}

.lamp {
  position: absolute;
  right: -70rpx;
  top: -20rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50% 50% 48% 52%;
  background: rgba(255, 226, 178, 0.62);
  filter: blur(2rpx);
}

.photo-stack {
  position: absolute;
  right: -20rpx;
  top: 95rpx;
  width: 360rpx;
  height: 448rpx;
}

.photo-shadow,
.portrait-photo {
  position: absolute;
  width: 326rpx;
  height: 414rpx;
  border: 14rpx solid #ffffff;
  border-bottom-width: 58rpx;
  border-radius: 12rpx;
  box-sizing: border-box;
  box-shadow: 0 18rpx 42rpx rgba(66, 41, 18, 0.18);
}

.photo-shadow {
  left: -44rpx;
  top: 28rpx;
  background: #eed1a8;
  transform: rotate(-8deg);
}

.portrait-photo {
  left: 10rpx;
  top: 0;
  background: #f5d6b3;
  transform: rotate(6deg);
}

.camera {
  position: absolute;
  left: -18rpx;
  bottom: 64rpx;
  width: 210rpx;
  height: 122rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #eee9df 0%, #171412 50%, #0f0e0d 100%);
}

.camera::after {
  content: "";
  position: absolute;
  left: 70rpx;
  top: 28rpx;
  width: 70rpx;
  height: 70rpx;
  border: 12rpx solid #2b2118;
  border-radius: 50%;
  background: #7a4f22;
}

.login-actions {
  position: relative;
  z-index: 2;
}

.guest-btn {
  width: 100%;
  height: 106rpx;
  margin: 28rpx 0 0;
  padding: 0;
  border: 2rpx solid rgba(180, 119, 0, 0.36);
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #2a1b10;
  font-size: 34rpx;
  line-height: 46rpx;
  font-weight: 700;
}

.guest-btn::after {
  border: 0;
}

.guest-icon {
  font-size: 42rpx;
  line-height: 42rpx;
}

.agreement-row {
  margin-top: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 34rpx;
}

.check {
  width: 34rpx;
  height: 34rpx;
  border: 2rpx solid rgba(71, 55, 36, 0.35);
  border-radius: 50%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 20rpx;
  flex: none;
}

.check.checked {
  border-color: #e4a21a;
  background: #e4a21a;
}

.agreement-text {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 4rpx;
}

.link {
  color: #b47700;
  font-weight: 700;
}
