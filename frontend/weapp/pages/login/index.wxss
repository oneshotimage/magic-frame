.login-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #f9f9f9;
  color: #27221c;
}

.warm-bg,
.glow {
  position: absolute;
  pointer-events: none;
}

.warm-bg {
  inset: 0;
  height: 1060rpx;
  background: linear-gradient(180deg, rgba(255, 222, 168, 0.3), rgba(255, 222, 168, 0));
}

.glow {
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  filter: blur(6rpx);
}

.glow-right {
  right: -156rpx;
  top: -156rpx;
  background: rgba(255, 181, 153, 0.2);
  filter: blur(80rpx);
}

.glow-left {
  left: -176rpx;
  top: 320rpx;
  background: rgba(255, 184, 0, 0.1);
  filter: blur(60rpx);
}

.login-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  height: 144rpx;
  padding: 32rpx 40rpx 0;
  box-sizing: border-box;
}

.back-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 50rpx;
  text-align: center;
  font-size: 48rpx;
  color: #2c251f;
}

.brand-panel {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 96rpx;
}

.app-logo {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 64rpx;
  background: linear-gradient(135deg, #ffb800 0%, #ff9d00 100%);
  box-shadow: 0 20rpx 30rpx rgba(255, 184, 0, 0.2);
}

.logo-spark {
  position: absolute;
  color: #fffdf7;
  font-weight: 700;
}

.logo-spark.main {
  left: 52rpx;
  top: 42rpx;
  font-size: 64rpx;
}

.logo-spark.small-a {
  right: 42rpx;
  bottom: 40rpx;
  font-size: 38rpx;
  opacity: 0.9;
}

.logo-spark.small-b {
  right: 58rpx;
  top: 38rpx;
  font-size: 24rpx;
  opacity: 0.72;
}

.brand-title {
  margin-top: 28rpx;
  font-size: 54rpx;
  line-height: 72rpx;
  font-weight: 500;
  letter-spacing: 0;
}

.brand-subtitle {
  width: 472rpx;
  margin-top: 8rpx;
  color: #666666;
  font-size: 27rpx;
  line-height: 40rpx;
  text-align: center;
}

.login-actions {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(64rpx + env(safe-area-inset-bottom));
  z-index: 2;
}

.wechat-btn,
.phone-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 104rpx;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 500;
  box-sizing: border-box;
}

.wechat-btn {
  gap: 14rpx;
  border: 0;
  background: #ffb800;
  color: #222222;
  box-shadow: 0 8rpx 12rpx rgba(255, 184, 0, 0.2);
}

.wechat-btn::after,
.phone-btn::after {
  border: 0;
}

.chat-icon {
  position: relative;
  width: 34rpx;
  height: 28rpx;
  border-radius: 15rpx;
  background: #312517;
}

.chat-icon::after {
  content: "";
  position: absolute;
  left: 8rpx;
  bottom: -5rpx;
  width: 12rpx;
  height: 12rpx;
  background: #312517;
  transform: rotate(45deg);
}

.phone-btn {
  margin-top: 32rpx;
  border: 4rpx solid rgba(255, 222, 168, 0.5);
  background: rgba(255, 255, 255, 0.8);
  color: #222222;
}

.agreement-row {
  display: flex;
  align-items: center;
  justify-content: center;
  align-items: flex-start;
  margin-top: 48rpx;
  color: #666666;
  font-size: 23rpx;
  line-height: 38rpx;
}

.check {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
  border-radius: 6rpx;
  border: 2rpx solid rgba(71, 55, 36, 0.3);
  color: #fff;
  font-size: 20rpx;
  box-sizing: border-box;
}

.check.checked {
  border-color: #e4a21a;
  background: #e4a21a;
}

.link {
  color: #8c5b06;
  font-weight: 600;
}
